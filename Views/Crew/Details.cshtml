        }

        .upd-table-wide {
            min-width: 1200px;
        }

        .upd-table thead {
            background: rgba(131, 157, 187, 0.7);
        }

        .upd-table th,
        .upd-table td {
            height: 75px;
            padding: 0 8px;
            font-size: 16px;
            white-space: nowrap;
            text-align: left;
        }

        .upd-table th {
            color: #364153;
            font-weight: 700;
            cursor: pointer;
            user-select: none;
            height: 64px;
            border-bottom: 0.8px solid rgba(0, 0, 0, 0.1);
        }

        .upd-sort::after {
            content: "\2195";
            color: #6a7890;
            margin-left: 10px;
            font-size: 16px;
