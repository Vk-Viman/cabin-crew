            display: flex;
            align-items: center;
            gap: 14px;
            flex: 1;
            min-width: 0;
        }

        .upd-search-group-flight,
        .upd-search-group-date,
        .upd-search-group-board {
            flex: 1 1 0;
        }

        .upd-search-group label {
            font-size: 16px;
            font-weight: 400;
            line-height: 14px;
            color: #1a1a1a;
            white-space: nowrap;
        }

        .upd-search-group input {
            flex: 1 1 auto;
            width: 100%;
            height: 56px;
            border: none;
            border-radius: 8px;
            padding: 0 12px;
            font-size: 16px;
            color: #717182;
            background: #f3f3f5;
            outline: none;
            box-sizing: border-box;
        }

        .upd-search-group input:focus {
            outline: none;
            background: #eceef2;
        }

        .upd-search-group input::placeholder {
