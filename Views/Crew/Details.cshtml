@{
    ViewData["Title"] = "Update Pilot Details";
}

<div class="upd-page">
    <section class="upd-card upd-search-card">
        <form id="updSearchForm" class="upd-search-row" autocomplete="off">
            <div class="upd-search-group upd-search-group-flight">
                <label for="updFlightNo">Flight No</label>
                <input id="updFlightNo" type="text" placeholder="ul" />
            </div>

            <div class="upd-search-group upd-search-group-date">
                <label for="updFlightDate">Flight Date (Local)</label>
                <div class="upd-date-wrap">
                    <input id="updFlightDate" type="date" />
                </div>
            </div>

            <div class="upd-search-group upd-search-group-board">
                <label for="updBoardPoint">Board Point</label>
                <input id="updBoardPoint" type="text" placeholder="cmb" />
            </div>

            <button id="updSearchBtn" type="submit" class="upd-search-btn">
                <img class="upd-search-icon"
                     src="http://localhost:3845/assets/8d5576640b13d512765bbe4597d5b9542d886612.svg" alt=""
                     aria-hidden="true" />
                <span>Search</span>
            </button>
        </form>
    </section>

    <section id="updEmptyState" class="upd-card upd-empty-card">
        <div class="upd-empty-icon-wrap">
            <img src="http://localhost:3845/assets/891a4a9cb6d25fc1b60faf0f44955f6eb74c2677.svg" alt=""
                 aria-hidden="true" />
        </div>
        <h3>Ready to Search</h3>
        <p>Use the filters above to search for Pilot Details by Flight.<br />Enter flight details to get started.</p>
    </section>

    <section id="updResultsCard" class="upd-card upd-table-card d-none">
        <div class="upd-toolbar">
            <div class="upd-toolbar-left">
                <span>Show</span>
                <select id="updEntries">
                    <option>10</option>
                    <option>25</option>
                    <option>50</option>
                </select>
                <span>entries</span>
                <span id="updRecordBadge" class="upd-badge">0 records</span>
            </div>

            <div class="upd-toolbar-right">
                <div class="upd-toolbar-search">
                    <input id="updTableSearch" type="text" placeholder="Search pilots..." />
                </div>
                <button id="updAddPilotBtn" type="button" class="upd-add-btn">+ Add Pilot</button>
            </div>
        </div>

        <div class="upd-table-wrap">
            <table class="upd-table">
                <thead>
                    <tr>
                        <th class="upd-sort" data-key="StaffID">Staff ID</th>
                        <th class="upd-sort" data-key="FirstName">First Name</th>
                        <th class="upd-sort" data-key="LastName">Last Name</th>
                        <th class="upd-sort" data-key="Departure">Departure</th>
                        <th class="upd-sort" data-key="Citizenship">Citizenship</th>
                        <th class="upd-sort" data-key="Sex">Sex</th>
                        <th class="upd-sort" data-key="IsLandingPilot">Is Landing Pilot</th>
                        <th class="upd-sort" data-key="IsOperatingPilot">Is Operating Pilot</th>
                        <th class="upd-sort" data-key="IsReliefPilot">Is Relief Pilot</th>
                    </tr>
                </thead>
                <tbody id="updTableBody"></tbody>
            </table>
        </div>

        <div class="upd-pagination">
            <span id="updTableInfo">Showing 0 to 0 of 0 entries</span>
            <div class="upd-pager">
                <button id="updPrev" type="button">Previous</button>
                <button id="updPage" type="button" class="active">1</button>
                <button id="updNext" type="button">Next</button>
            </div>
        </div>
    </section>

    <section id="updFormCard" class="upd-card upd-form-card d-none">
        <header class="upd-form-header">
            <img src="http://localhost:3845/assets/10c0d8e8fa1e47c86abf37436145f3800f994134.svg" alt="" />
            <h3 id="updFormTitle">Update Pilot Details</h3>
        </header>

        <form id="updPilotForm" class="upd-grid-form">
            <div class="upd-form-field">
                <label for="updSelectedFlightNo">Selected Flight No *</label>
                <input id="updSelectedFlightNo" type="text" readonly />
            </div>
            <div class="upd-form-field">
                <label for="updSelectedDate">Selected Flight Date *</label>
                <input id="updSelectedDate" type="text" readonly />
            </div>
            <div class="upd-form-field">
                <label for="updSelectedBoardPoint">Selected Boardpoint *</label>
                <input id="updSelectedBoardPoint" type="text" readonly />
            </div>
            <div class="upd-form-field">
                <label for="updSex">Sex</label>
                <input id="updSex" type="text" />
            </div>

            <div class="upd-form-field">
                <label for="updStaffId">Staff ID *</label>
                <input id="updStaffId" type="text" readonly />
            </div>
            <div class="upd-form-field">
                <label for="updFirstName">First Name *</label>
                <input id="updFirstName" type="text" />
            </div>
            <div class="upd-form-field">
                <label for="updLastName">Last Name *</label>
                <input id="updLastName" type="text" />
            </div>
            <div class="upd-form-field">
                <label for="updCitizenship">Citizenship</label>
                <input id="updCitizenship" type="text" />
            </div>

            <div class="upd-form-field">
                <label for="updDeparture">Departure</label>
                <input id="updDeparture" type="text" />
            </div>
            <div class="upd-form-field">
                <label for="updLandingPilot">Is Landing Pilot</label>
                <select id="updLandingPilot">
                    <option>Yes</option>
                    <option>No</option>
                </select>
            </div>
            <div class="upd-form-field">
                <label for="updOperatingPilot">Is Operating Pilot</label>
                <select id="updOperatingPilot">
                    <option>Yes</option>
                    <option>No</option>
                </select>
            </div>
            <div class="upd-form-field">
                <label for="updReliefPilot">Is Relief Pilot</label>
                <select id="updReliefPilot">
                    <option>No</option>
                    <option>Yes</option>
                </select>
            </div>
        </form>

        <div class="upd-form-actions">
            <button id="updSubmitBtn" type="button" class="upd-primary-btn">Add Pilot</button>
            <button id="updCancelBtn" type="button" class="upd-secondary-btn">Cancel</button>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const pilots = [
                {
                    FlightNo: "UL101",
                    Date: "2025-11-20",
                    BoardPoint: "CMB",
                    StaffID: "PLT-001",
                    FirstName: "James",
                    LastName: "Anderson",
                    Departure: "CMB",
                    Citizenship: "LK",
                    Sex: "Male",
                    IsLandingPilot: "Yes",
                    IsOperatingPilot: "Yes",
                    IsReliefPilot: "No"
                },
                {
                    FlightNo: "UL101",
                    Date: "2025-11-20",
                    BoardPoint: "CMB",
                    StaffID: "PLT-002",
                    FirstName: "Robert",
                    LastName: "Williams",
                    Departure: "CMB",
                    Citizenship: "LK",
                    Sex: "Male",
                    IsLandingPilot: "No",
                    IsOperatingPilot: "No",
                    IsReliefPilot: "Yes"
                }
            ];

            const state = {
                searched: false,
                selectedStaffId: "",
                filterFlightNo: "",
                filterDate: "",
                filterBoardPoint: "",
                search: "",
                entries: 10,
                page: 1,
                sort: { key: "StaffID", dir: "asc" },
                isNew: false
            };

            const el = {
                searchForm: document.getElementById("updSearchForm"),
                flightNo: document.getElementById("updFlightNo"),
                flightDate: document.getElementById("updFlightDate"),
                boardPoint: document.getElementById("updBoardPoint"),
                emptyState: document.getElementById("updEmptyState"),
                resultsCard: document.getElementById("updResultsCard"),
                formCard: document.getElementById("updFormCard"),
                tableBody: document.getElementById("updTableBody"),
                recordBadge: document.getElementById("updRecordBadge"),
                tableSearch: document.getElementById("updTableSearch"),
                entries: document.getElementById("updEntries"),
                tableInfo: document.getElementById("updTableInfo"),
                prev: document.getElementById("updPrev"),
                page: document.getElementById("updPage"),
                next: document.getElementById("updNext"),
                addPilotBtn: document.getElementById("updAddPilotBtn"),
                cancelBtn: document.getElementById("updCancelBtn"),
                submitBtn: document.getElementById("updSubmitBtn"),
                selectedFlightNo: document.getElementById("updSelectedFlightNo"),
                selectedDate: document.getElementById("updSelectedDate"),
                selectedBoardPoint: document.getElementById("updSelectedBoardPoint"),
                staffId: document.getElementById("updStaffId"),
                firstName: document.getElementById("updFirstName"),
                lastName: document.getElementById("updLastName"),
                departure: document.getElementById("updDeparture"),
                citizenship: document.getElementById("updCitizenship"),
                sex: document.getElementById("updSex"),
                landingPilot: document.getElementById("updLandingPilot"),
                operatingPilot: document.getElementById("updOperatingPilot"),
                reliefPilot: document.getElementById("updReliefPilot")
            };

            function normalizeDateInput(value) {
                const raw = (value || "").trim();
                if (!raw) return "";
                if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
                const match = raw.match(/^(\d{2})\/(\d{2})\/(\d{2}|\d{4})$/);
                if (!match) return "";
                const day = match[1];
                const month = match[2];
                const year = match[3].length === 2 ? `20${match[3]}` : match[3];
                return `${year}-${month}-${day}`;
            }

            function sortRows(rows, sort) {
                return [...rows].sort((a, b) => {
                    const av = String(a[sort.key] ?? "").toLowerCase();
                    const bv = String(b[sort.key] ?? "").toLowerCase();
                    if (av < bv) return sort.dir === "asc" ? -1 : 1;
                    if (av > bv) return sort.dir === "asc" ? 1 : -1;
                    return 0;
                });
            }

            function toggleSort(current, key) {
                if (current.key === key) {
                    current.dir = current.dir === "asc" ? "desc" : "asc";
                } else {
                    current.key = key;
                    current.dir = "asc";
                }
            }

            function filterRows() {
                let rows = [...pilots];

                const flightNo = state.filterFlightNo.toLowerCase();
                const boardPoint = state.filterBoardPoint.toLowerCase();
                const date = state.filterDate;

                if (flightNo) rows = rows.filter((r) => r.FlightNo.toLowerCase().includes(flightNo));
                if (boardPoint) rows = rows.filter((r) => r.BoardPoint.toLowerCase().includes(boardPoint));
                if (date) rows = rows.filter((r) => r.Date === date);

                const q = state.search.toLowerCase();
                if (q) {
                    rows = rows.filter((r) => Object.values(r).some((v) => String(v).toLowerCase().includes(q)));
                }

                return sortRows(rows, state.sort);
            }

            function getStatusChip(value) {
                const yes = String(value).toLowerCase() === "yes";
                return `<span class="upd-status ${yes ? "yes" : "no"}">${yes ? "YES" : "NO"}</span>`;
            }

            function renderTable() {
                const rows = filterRows();
                const pageSize = state.entries;
                const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                if (state.page > totalPages) state.page = totalPages;
                const start = (state.page - 1) * pageSize;
                const visible = rows.slice(start, start + pageSize);

                el.recordBadge.textContent = `${rows.length} records`;
                el.page.textContent = String(state.page);
                el.prev.disabled = state.page <= 1;
                el.next.disabled = state.page >= totalPages;
                const from = rows.length ? start + 1 : 0;
                const to = start + visible.length;
                el.tableInfo.textContent = `Showing ${from} to ${to} of ${rows.length} entries`;

                el.tableBody.innerHTML = visible.length
                    ? visible.map((r) => `
                                <tr class="upd-click-row" data-staffid="${r.StaffID}">
                                    <td>${r.StaffID}</td>
                                    <td>${r.FirstName}</td>
                                    <td>${r.LastName}</td>
                                    <td>${r.Departure}</td>
                                    <td>${r.Citizenship}</td>
                                    <td>${r.Sex}</td>
                                    <td>${getStatusChip(r.IsLandingPilot)}</td>
                                    <td>${getStatusChip(r.IsOperatingPilot)}</td>
                                    <td>${getStatusChip(r.IsReliefPilot)}</td>
                                </tr>
                            `).join("")
                    : `<tr><td colspan="9" class="upd-empty-row">No matching pilots found</td></tr>`;

                document.querySelectorAll(".upd-click-row").forEach((row) => {
                    row.addEventListener("click", function () {
                        const staffId = this.dataset.staffid || "";
                        const pilot = pilots.find((p) => p.StaffID === staffId);
                        if (!pilot) return;
                        state.selectedStaffId = staffId;
                        populateForm(pilot, false);
                        el.formCard.classList.remove("d-none");
                    });
                });
            }

            function populateForm(pilot, isNew) {
                state.isNew = isNew;
                el.selectedFlightNo.value = state.filterFlightNo || pilot.FlightNo || "";
                el.selectedDate.value = state.filterDate || pilot.Date || "";
                el.selectedBoardPoint.value = state.filterBoardPoint || pilot.BoardPoint || "";

                el.staffId.value = isNew ? `PLT-${String(pilots.length + 1).padStart(3, "0")}` : pilot.StaffID;
                el.firstName.value = isNew ? "" : pilot.FirstName;
                el.lastName.value = isNew ? "" : pilot.LastName;
                el.departure.value = isNew ? (state.filterBoardPoint || "") : pilot.Departure;
                el.citizenship.value = isNew ? "LK" : pilot.Citizenship;
                el.sex.value = isNew ? "Male" : pilot.Sex;
                el.landingPilot.value = isNew ? "Yes" : pilot.IsLandingPilot;
                el.operatingPilot.value = isNew ? "Yes" : pilot.IsOperatingPilot;
                el.reliefPilot.value = isNew ? "No" : pilot.IsReliefPilot;
                el.submitBtn.textContent = isNew ? "Add Pilot" : "Update Pilot";
                document.getElementById("updFormTitle").textContent = isNew ? "Add Pilot Details" : "Update Pilot Details";
                if (isNew) {
                    el.submitBtn.classList.add("add-mode");
                } else {
                    el.submitBtn.classList.remove("add-mode");
                }
            }

            function renderView() {
                if (!state.searched) {
                    el.emptyState.classList.remove("d-none");
                    el.resultsCard.classList.add("d-none");
                    el.formCard.classList.add("d-none");
                    return;
                }

                const rows = filterRows();
                if (!rows.length) {
                    el.emptyState.classList.remove("d-none");
                    el.resultsCard.classList.add("d-none");
                    el.formCard.classList.add("d-none");
                    el.emptyState.querySelector("h3").textContent = "No Results Found";
                    el.emptyState.querySelector("p").innerHTML = "No pilot details matched your filters.<br />Try another Flight No, date, or board point.";
                    return;
                }

                el.emptyState.classList.add("d-none");
                el.resultsCard.classList.remove("d-none");
                renderTable();
            }

            el.searchForm.addEventListener("submit", function (e) {
                e.preventDefault();
                state.filterFlightNo = el.flightNo.value.trim();
                state.filterDate = normalizeDateInput(el.flightDate.value);
                state.filterBoardPoint = el.boardPoint.value.trim();
                state.search = "";
                el.tableSearch.value = "";
                state.page = 1;
                state.searched = true;
                renderView();
            });

            el.tableSearch.addEventListener("input", function () {
                state.search = this.value.trim();
                state.page = 1;
                renderTable();
            });

            el.entries.addEventListener("change", function () {
                state.entries = parseInt(this.value, 10);
                state.page = 1;
                renderTable();
            });

            el.prev.addEventListener("click", function () {
                if (state.page <= 1) return;
                state.page -= 1;
                renderTable();
            });

            el.next.addEventListener("click", function () {
                const total = filterRows().length;
                const pages = Math.max(1, Math.ceil(total / state.entries));
                if (state.page >= pages) return;
                state.page += 1;
                renderTable();
            });

            el.addPilotBtn.addEventListener("click", function () {
                populateForm({
                    FlightNo: state.filterFlightNo,
                    Date: state.filterDate,
                    BoardPoint: state.filterBoardPoint,
                    Departure: state.filterBoardPoint,
                    StaffID: `PLT-${String(pilots.length + 1).padStart(3, "0")}`,
                    FirstName: "",
                    LastName: "",
                    Citizenship: "LK",
                    Sex: "Male",
                    IsLandingPilot: "Yes",
                    IsOperatingPilot: "Yes",
                    IsReliefPilot: "No"
                }, true);
                el.formCard.classList.remove("d-none");
            });

            el.cancelBtn.addEventListener("click", function () {
                el.formCard.classList.add("d-none");
            });

            el.submitBtn.addEventListener("click", function () {
                el.formCard.classList.add("d-none");
            });

            document.querySelectorAll(".upd-sort").forEach((th) => {
                th.addEventListener("click", function () {
                    toggleSort(state.sort, this.dataset.key);
                    state.page = 1;
                    renderTable();
                });
            });

            renderView();
        });
    </script>
}

@section Styles {
    <style>
        .upd-page {
            max-width: 1574px;
            margin: 0 auto;
            padding: 4px 0 32px;
            font-family: Arial, sans-serif;
            color: #1a1a1a;
        }

        .upd-card {
            background: #ffffff;
            border-radius: 14px;
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1), 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 28px;
        }

        .upd-search-card {
            min-height: 128px;
            padding: 16px 33px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .upd-search-row {
            display: flex;
            align-items: center;
            gap: 30px;
            width: 100%;
            margin: 0;
            max-width: 1320px;
        }

