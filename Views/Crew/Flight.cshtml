@{
    ViewData["Title"] = "Cabin Crew by Flight";
}

<div class="cbf-page">
    <section id="cbfFilterSection" class="cbf-card cbf-search-card">
        <div class="cbf-search-row">
            <div class="cbf-search-group cbf-search-group-flight">
                <label for="cbfFilterFlightNo">Flight No</label>
                <input id="cbfFilterFlightNo" type="text" placeholder="ul" />
            </div>
            <div class="cbf-search-group cbf-search-group-date">
                <label for="cbfFilterDate">Flight Date (Local)</label>
                <div class="cbf-date-wrap">
                    <input id="cbfFilterDate" type="date" />
                </div>
            </div>
            <div class="cbf-search-group cbf-search-group-board">
                <label for="cbfFilterBoardPoint">Board Point</label>
                <input id="cbfFilterBoardPoint" type="text" placeholder="cmb" />
            </div>
            <button id="cbfFilterSearchBtn" type="button" class="cbf-search-btn">
                <svg class="cbf-search-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                    <circle cx="11" cy="11" r="6" stroke="currentColor" stroke-width="2" />
                    <path d="M15.5 15.5L20 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <span>Search</span>
            </button>
        </div>
    </section>

    <section id="cbfEmptyState" class="cbf-card cbf-empty-card">
        <div class="cbf-empty-icon">
            <img src="@Url.Content("~/images/icons/Icon-13.svg")" alt="" aria-hidden="true" />
        </div>
        <h3>Ready to Search</h3>
        <p>Use the filters above to search for cabin crew assignments<br />by flight. Enter flight details to get
            started.</p>
        </section>

        <section id="cbfSummarySection" class="cbf-card cbf-table-card d-none">
            <div class="cbf-toolbar">
                <div class="cbf-toolbar-left">
                    <span>Show</span>
                    <select id="cbfSummaryEntries">
                        <option>10</option>
                        <option>25</option>
                        <option>50</option>
                    </select>
                    <span>entries</span>
                    <span id="cbfSummaryBadge" class="cbf-badge">0 records</span>
                </div>
                <div class="cbf-toolbar-search">
                    <input id="cbfSummarySearch" type="text" placeholder="Search by flight number..." />
                </div>
            </div>

            <div class="cbf-table-wrap">
                <table class="cbf-table">
                    <thead>
                        <tr>
                            <th class="cbf-sort" data-table="summary" data-key="FlightNo">Flight No</th>
                            <th class="cbf-sort" data-table="summary" data-key="BoardPoint">Board Point</th>
                            <th class="cbf-sort" data-table="summary" data-key="OffPoint">Off Point</th>
                            <th class="cbf-sort" data-table="summary" data-key="CrewCount">Crew Count</th>
                        </tr>
                    </thead>
                    <tbody id="cbfSummaryBody"></tbody>
                </table>
            </div>

            <div class="cbf-pagination">
                <span id="cbfSummaryInfo">Showing 0 to 0 of 0 entries</span>
                <div class="cbf-pager">
                    <button id="cbfSummaryPrev" type="button">Previous</button>
                    <button id="cbfSummaryPage" type="button" class="active">1</button>
                    <button id="cbfSummaryNext" type="button">Next</button>
                </div>
            </div>
        </section>

        <section id="cbfDetailSection" class="d-none">
            <button id="cbfBackBtn" type="button" class="cbf-back-link">Back to Cabin Crew</button>

            <section class="cbf-banner">
                <div class="cbf-banner-left">
                    <div class="cbf-banner-icon">&#9992;</div>
                    <div id="cbfBannerFlight" class="cbf-banner-main">Flight UL504</div>
                    <div id="cbfBannerRoute" class="cbf-banner-main">CMB &rarr; KUL</div>
                    <div id="cbfBannerDate" class="cbf-banner-main">20 / 11 / 2025</div>
                </div>
                <div class="cbf-banner-right">
                    <div class="cbf-banner-chip"><span>Cabin Crew</span><strong id="cbfBannerCrewCount">0</strong></div>
                    <div class="cbf-banner-chip"><span>SNY Crew</span><strong id="cbfBannerSnyCount">0</strong></div>
                </div>
            </section>

            <section class="cbf-card cbf-detail-card">
                <header class="cbf-detail-header">
                    <img src="@Url.Content("~/images/icons/Icon-1.svg")" alt="" />
                    <h3 id="cbfCrewTitle">Cabin Crew Members (0 members)</h3>
                </header>

                <div class="cbf-toolbar">
                    <div class="cbf-toolbar-left">
                        <span>Show</span>
                        <select id="cbfCrewEntries">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                        <span>entries</span>
                        <span id="cbfCrewBadge" class="cbf-badge">0 records</span>
                    </div>
                    <div class="cbf-toolbar-search">
                        <input id="cbfCrewSearch" type="text" placeholder="Search crew members..." />
                    </div>
                </div>

                <div class="cbf-table-wrap">
                    <table class="cbf-table cbf-table-wide">
                        <thead>
                            <tr>
                                <th class="cbf-sort" data-table="crew" data-key="CAT">CAT</th>
                                <th class="cbf-sort" data-table="crew" data-key="EMPNo">EMP No</th>
                                <th class="cbf-sort" data-table="crew" data-key="Name">Name</th>
                                <th class="cbf-sort" data-table="crew" data-key="PromotionDate">Date of Promotion</th>
                                <th class="cbf-sort" data-table="crew" data-key="Gender">Gender</th>
                                <th class="cbf-sort" data-table="crew" data-key="Nationality">Nationality</th>
                                <th class="cbf-sort" data-table="crew" data-key="Onboard">Onboard</th>
                                <th class="cbf-sort" data-table="crew" data-key="Position">Position</th>
                                <th class="cbf-sort" data-table="crew" data-key="SafetySign">Safety Sign</th>
                                <th class="cbf-sort" data-table="crew" data-key="Sign">Sign</th>
                            </tr>
                        </thead>
                        <tbody id="cbfCrewBody"></tbody>
                    </table>
                </div>

                <div class="cbf-pagination">
                    <span id="cbfCrewInfo">Showing 0 to 0 of 0 entries</span>
                    <div class="cbf-pager">
                        <button id="cbfCrewPrev" type="button">Previous</button>
                        <button id="cbfCrewPage" type="button" class="active">1</button>
                        <button id="cbfCrewNext" type="button">Next</button>
                    </div>
                </div>
            </section>

            <section class="cbf-card cbf-detail-card">
                <header class="cbf-detail-header">
                    <img src="@Url.Content("~/images/icons/Icon-1.svg")" alt="" />
                    <h3 id="cbfSnyTitle">SNY Crew (0 members)</h3>
                </header>

                <div class="cbf-toolbar">
                    <div class="cbf-toolbar-left">
                        <span>Show</span>
                        <select id="cbfSnyEntries">
                            <option>10</option>
                            <option>25</option>
                            <option>50</option>
                        </select>
                        <span>entries</span>
                        <span id="cbfSnyBadge" class="cbf-badge">0 records</span>
                    </div>
                    <div class="cbf-toolbar-search">
                        <input id="cbfSnySearch" type="text" placeholder="Search SNY crew..." />
                    </div>
                </div>

                <div class="cbf-table-wrap">
                    <table class="cbf-table">
                        <thead>
                            <tr>
                                <th class="cbf-sort" data-table="sny" data-key="CAT">CAT</th>
                                <th class="cbf-sort" data-table="sny" data-key="Position">Position</th>
                                <th class="cbf-sort" data-table="sny" data-key="Name">Name</th>
                                <th class="cbf-sort" data-table="sny" data-key="StaffID">Staff ID</th>
                                <th class="cbf-sort" data-table="sny" data-key="Sign">Sign</th>
                            </tr>
                        </thead>
                        <tbody id="cbfSnyBody"></tbody>
                    </table>
                </div>

                <div class="cbf-pagination">
                    <span id="cbfSnyInfo">Showing 0 to 0 of 0 entries</span>
                    <div class="cbf-pager">
                        <button id="cbfSnyPrev" type="button">Previous</button>
                        <button id="cbfSnyPage" type="button" class="active">1</button>
                        <button id="cbfSnyNext" type="button">Next</button>
                    </div>
                </div>
            </section>
        </section>
    </div>

    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const mockFlights = [
                    { FlightNo: "UL101", Date: "2025-11-20", BoardPoint: "CMB", OffPoint: "LHR", CrewCount: 2 },
                    { FlightNo: "UL205", Date: "2025-11-20", BoardPoint: "CMB", OffPoint: "BKK", CrewCount: 1 },
                    { FlightNo: "UL504", Date: "2025-11-20", BoardPoint: "CMB", OffPoint: "KUL", CrewCount: 4 }
                ];

                const mockCrewByFlight = {
                    UL101: [
                        { CAT: "PUR", EMPNo: "CCM-456", Name: "Sarah Johnson", PromotionDate: "2023-01-15", Gender: "Female", Nationality: "LK", Onboard: "Yes", Position: "L1", SafetySign: "Yes", Sign: "Yes" },
                        { CAT: "CS", EMPNo: "CCM-789", Name: "David Lee", PromotionDate: "2024-03-20", Gender: "Male", Nationality: "LK", Onboard: "Yes", Position: "R4", SafetySign: "Yes", Sign: "Yes" }
                    ],
                    UL205: [
                        { CAT: "FA", EMPNo: "CCM-852", Name: "Break Lee", PromotionDate: "2024-03-20", Gender: "Male", Nationality: "LK", Onboard: "Yes", Position: "L4", SafetySign: "Yes", Sign: "Yes" }
                    ],
                    UL504: [
                        { CAT: "PUR", EMPNo: "CCM-456", Name: "Sarah Johnson", PromotionDate: "2023-01-15", Gender: "Female", Nationality: "LK", Onboard: "Yes", Position: "L1", SafetySign: "Yes", Sign: "Yes" },
                        { CAT: "CS", EMPNo: "CCM-789", Name: "David Lee", PromotionDate: "2024-03-20", Gender: "Male", Nationality: "LK", Onboard: "Yes", Position: "R4", SafetySign: "Yes", Sign: "Yes" },
                        { CAT: "FA", EMPNo: "CCM-852", Name: "Break Lee", PromotionDate: "2024-03-20", Gender: "Male", Nationality: "LK", Onboard: "Yes", Position: "L4", SafetySign: "Yes", Sign: "Yes" },
                        { CAT: "FA", EMPNo: "CCM-856", Name: "Dave Lee", PromotionDate: "2024-03-20", Gender: "Male", Nationality: "LK", Onboard: "No", Position: "L3", SafetySign: "No", Sign: "No" }
                    ]
                };

                const mockSnyByFlight = {
                    UL101: [{ CAT: "PUR", Position: "L1", Name: "Alice Brown", StaffID: "CCM-901", Sign: "Yes" }],
                    UL205: [{ CAT: "CS", Position: "R4", Name: "Robert Smith", StaffID: "CCM-902", Sign: "Yes" }],
                    UL504: [
                        { CAT: "PUR", Position: "L1", Name: "Alice Brown", StaffID: "CCM-901", Sign: "Yes" },
                        { CAT: "CS", Position: "R4", Name: "Robert Smith", StaffID: "CCM-902", Sign: "Yes" }
                    ]
                };

                const state = {
                    searched: false,
                    selectedFlight: "",
                    filterFlightNo: "",
                    filterDate: "",
                    filterBoardPoint: "",
                    summarySearch: "",
                    summaryEntries: 10,
                    summaryPage: 1,
                    summarySort: { key: "FlightNo", dir: "asc" },
                    crewSearch: "",
                    crewEntries: 10,
                    crewPage: 1,
                    crewSort: { key: "Name", dir: "asc" },
                    snySearch: "",
                    snyEntries: 10,
                    snyPage: 1,
                    snySort: { key: "Name", dir: "asc" }
                };

                const el = {
                    filterSection: document.getElementById("cbfFilterSection"),
                    filterFlightNo: document.getElementById("cbfFilterFlightNo"),
                    filterDate: document.getElementById("cbfFilterDate"),
                    filterBoardPoint: document.getElementById("cbfFilterBoardPoint"),
                    filterSearchBtn: document.getElementById("cbfFilterSearchBtn"),
                    emptyState: document.getElementById("cbfEmptyState"),
                    summarySection: document.getElementById("cbfSummarySection"),
                    summaryBody: document.getElementById("cbfSummaryBody"),
                    summaryBadge: document.getElementById("cbfSummaryBadge"),
                    summarySearch: document.getElementById("cbfSummarySearch"),
                    summaryEntries: document.getElementById("cbfSummaryEntries"),
                    summaryInfo: document.getElementById("cbfSummaryInfo"),
                    summaryPrev: document.getElementById("cbfSummaryPrev"),
                    summaryPage: document.getElementById("cbfSummaryPage"),
                    summaryNext: document.getElementById("cbfSummaryNext"),
                    detailSection: document.getElementById("cbfDetailSection"),
                    backBtn: document.getElementById("cbfBackBtn"),
                    bannerFlight: document.getElementById("cbfBannerFlight"),
                    bannerRoute: document.getElementById("cbfBannerRoute"),
                    bannerDate: document.getElementById("cbfBannerDate"),
                    bannerCrewCount: document.getElementById("cbfBannerCrewCount"),
                    bannerSnyCount: document.getElementById("cbfBannerSnyCount"),
                    crewTitle: document.getElementById("cbfCrewTitle"),
                    crewBody: document.getElementById("cbfCrewBody"),
                    crewBadge: document.getElementById("cbfCrewBadge"),
                    crewEntries: document.getElementById("cbfCrewEntries"),
                    crewSearchInput: document.getElementById("cbfCrewSearch"),
                    crewInfo: document.getElementById("cbfCrewInfo"),
                    crewPrev: document.getElementById("cbfCrewPrev"),
                    crewPage: document.getElementById("cbfCrewPage"),
                    crewNext: document.getElementById("cbfCrewNext"),
                    snyTitle: document.getElementById("cbfSnyTitle"),
                    snyBody: document.getElementById("cbfSnyBody"),
                    snyBadge: document.getElementById("cbfSnyBadge"),
                    snyEntries: document.getElementById("cbfSnyEntries"),
                    snySearchInput: document.getElementById("cbfSnySearch"),
                    snyInfo: document.getElementById("cbfSnyInfo"),
                    snyPrev: document.getElementById("cbfSnyPrev"),
                    snyPage: document.getElementById("cbfSnyPage"),
                    snyNext: document.getElementById("cbfSnyNext")
                };

                function dateLabel(value) {
                    if (!value) return "";
                    const parts = value.split("-");
                    if (parts.length !== 3) return value;
                    return `${parts[2]} / ${parts[1]} / ${parts[0]}`;
                }

                function sortRows(rows, sort) {
                    return [...rows].sort((a, b) => {
                        const av = String(a[sort.key] ?? "").toLowerCase();
                        const bv = String(b[sort.key] ?? "").toLowerCase();
                        if (av < bv) return sort.dir === "asc" ? -1 : 1;
                        if (av > bv) return sort.dir === "asc" ? 1 : -1;
                        return 0;
                    });
                }

                function toggleSort(current, key) {
                    if (current.key === key) {
                        current.dir = current.dir === "asc" ? "desc" : "asc";
                    } else {
                        current.key = key;
                        current.dir = "asc";
                    }
                }

                function filterFlights() {
                    let rows = [...mockFlights];

                    const flightNo = state.filterFlightNo.toLowerCase();
                    const boardPoint = state.filterBoardPoint.toLowerCase();
                    const date = state.filterDate;

                    if (flightNo) {
                        rows = rows.filter((r) => r.FlightNo.toLowerCase().includes(flightNo));
                    }

                    if (boardPoint) {
                        rows = rows.filter((r) => r.BoardPoint.toLowerCase().includes(boardPoint));
                    }

                    if (date) {
                        rows = rows.filter((r) => r.Date === date);
                    }

                    const summarySearch = state.summarySearch.toLowerCase();
                    if (summarySearch) {
                        rows = rows.filter((r) => r.FlightNo.toLowerCase().includes(summarySearch));
                    }

                    return sortRows(rows, state.summarySort);
                }

                function normalizeDateInput(value) {
                    const raw = (value || "").trim();
                    if (!raw) return "";

                    if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;

                    const match = raw.match(/^(\d{2})\/(\d{2})\/(\d{2}|\d{4})$/);
                    if (!match) return "";

                    const day = match[1];
                    const month = match[2];
                    const yearRaw = match[3];
                    const year = yearRaw.length === 2 ? `20${yearRaw}` : yearRaw;
                    return `${year}-${month}-${day}`;
                }

                function renderSummary() {
                    const rows = filterFlights();
                    const pageSize = state.summaryEntries;
                    const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                    if (state.summaryPage > totalPages) state.summaryPage = totalPages;
                    const start = (state.summaryPage - 1) * pageSize;
                    const visible = rows.slice(start, start + pageSize);

                    el.summaryBadge.textContent = `${rows.length} records`;
                    el.summaryPage.textContent = String(state.summaryPage);
                    el.summaryPrev.disabled = state.summaryPage <= 1;
                    el.summaryNext.disabled = state.summaryPage >= totalPages;
                    const from = rows.length ? start + 1 : 0;
                    const to = start + visible.length;
                    el.summaryInfo.textContent = `Showing ${from} to ${to} of ${rows.length} entries`;

                    el.summaryBody.innerHTML = visible.length
                        ? visible.map((r) => `
                                <tr class="cbf-click-row" data-flight="${r.FlightNo}">
                                    <td>${r.FlightNo}</td>
                                    <td>${r.BoardPoint}</td>
                                    <td>${r.OffPoint}</td>
                                    <td>${r.CrewCount}</td>
                                </tr>
                            `).join("")
                        : `<tr><td colspan="4" class="cbf-empty-row">No matching flights found</td></tr>`;

                    document.querySelectorAll(".cbf-click-row").forEach((row) => {
                        row.addEventListener("click", function () {
                            state.selectedFlight = this.dataset.flight || "";
                            state.crewSearch = "";
                            state.snySearch = "";
                            if (el.crewSearchInput) el.crewSearchInput.value = "";
                            if (el.snySearchInput) el.snySearchInput.value = "";
                            state.crewPage = 1;
                            state.snyPage = 1;
                            renderView();
                        });
                    });
                }

                function tableStateRows(sourceRows, searchValue, sortState) {
                    let rows = sourceRows;
                    const q = searchValue.toLowerCase();
                    if (q) {
                        rows = rows.filter((r) => Object.values(r).some((v) => String(v).toLowerCase().includes(q)));
                    }
                    return sortRows(rows, sortState);
                }

                function renderCrewDetails() {
                    const rows = mockCrewByFlight[state.selectedFlight] || [];
                    const filtered = tableStateRows(rows, state.crewSearch, state.crewSort);
                    const pageSize = state.crewEntries;
                    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
                    if (state.crewPage > totalPages) state.crewPage = totalPages;
                    const start = (state.crewPage - 1) * pageSize;
                    const visible = filtered.slice(start, start + pageSize);

                    el.crewTitle.textContent = `Cabin Crew Members (${rows.length} members)`;
                    el.crewBadge.textContent = `${rows.length} records`;
                    el.crewPage.textContent = String(state.crewPage);
                    el.crewPrev.disabled = state.crewPage <= 1;
                    el.crewNext.disabled = state.crewPage >= totalPages;
                    const from = filtered.length ? start + 1 : 0;
                    const to = start + visible.length;
                    el.crewInfo.textContent = `Showing ${from} to ${to} of ${filtered.length} entries`;

                    el.crewBody.innerHTML = visible.length
                        ? visible.map((r) => `
                                <tr>
                                    <td><span class="cbf-chip">${r.CAT}</span></td>
                                    <td>${r.EMPNo}</td>
                                    <td>${r.Name}</td>
                                    <td>${r.PromotionDate}</td>
                                    <td>${r.Gender}</td>
                                    <td>${r.Nationality}</td>
                                    <td>${r.Onboard === "Yes" ? "<span class=\"cbf-status-yes\">&#10003;</span>" : "<span class=\"cbf-status-no\">&#9675;</span>"}</td>
                                    <td>${r.Position}</td>
                                    <td>${r.SafetySign === "Yes" ? "<span class=\"cbf-status-yes\">&#10003;</span>" : "<span class=\"cbf-status-no\">&#9675;</span>"}</td>
                                    <td><span class="cbf-sign ${r.Sign === "Yes" ? "yes" : "no"}">${r.Sign}</span></td>
                                </tr>
                            `).join("")
                        : `<tr><td colspan="10" class="cbf-empty-row">No matching crew members</td></tr>`;
                }

                function renderSnyDetails() {
                    const rows = mockSnyByFlight[state.selectedFlight] || [];
                    const filtered = tableStateRows(rows, state.snySearch, state.snySort);
                    const pageSize = state.snyEntries;
                    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
                    if (state.snyPage > totalPages) state.snyPage = totalPages;
                    const start = (state.snyPage - 1) * pageSize;
                    const visible = filtered.slice(start, start + pageSize);

                    el.snyTitle.textContent = `SNY Crew (${rows.length} members)`;
                    el.snyBadge.textContent = `${rows.length} records`;
                    el.snyPage.textContent = String(state.snyPage);
                    el.snyPrev.disabled = state.snyPage <= 1;
                    el.snyNext.disabled = state.snyPage >= totalPages;
                    const from = filtered.length ? start + 1 : 0;
                    const to = start + visible.length;
                    el.snyInfo.textContent = `Showing ${from} to ${to} of ${filtered.length} entries`;

                    el.snyBody.innerHTML = visible.length
                        ? visible.map((r) => `
                                <tr>
                                    <td><span class="cbf-chip">${r.CAT}</span></td>
                                    <td>${r.Position}</td>
                                    <td>${r.Name}</td>
                                    <td>${r.StaffID}</td>
                                    <td><span class="cbf-sign yes">${r.Sign}</span></td>
                                </tr>
                            `).join("")
                        : `<tr><td colspan="5" class="cbf-empty-row">No SNY crew found</td></tr>`;
                }

                function renderBanner() {
                    const selected = mockFlights.find((f) => f.FlightNo === state.selectedFlight);
                    if (!selected) return;
                    const snyCount = (mockSnyByFlight[state.selectedFlight] || []).length;

                    el.bannerFlight.textContent = `Flight ${selected.FlightNo}`;
                    el.bannerRoute.innerHTML = `${selected.BoardPoint} &rarr; ${selected.OffPoint}`;
                    el.bannerDate.textContent = dateLabel(selected.Date);
                    el.bannerCrewCount.textContent = String(selected.CrewCount);
                    el.bannerSnyCount.textContent = String(snyCount);
                }

                function renderView() {
                    if (state.selectedFlight) {
                        el.filterSection.classList.add("d-none");
                        el.emptyState.classList.add("d-none");
                        el.summarySection.classList.add("d-none");
                        el.detailSection.classList.remove("d-none");
                        renderBanner();
                        renderCrewDetails();
                        renderSnyDetails();
                        return;
                    }

                    el.detailSection.classList.add("d-none");
                    el.filterSection.classList.remove("d-none");
                    const rows = filterFlights();

                    if (!state.searched) {
                        el.emptyState.classList.remove("d-none");
                        el.summarySection.classList.add("d-none");
                        el.emptyState.querySelector("h3").textContent = "Ready to Search";
                        el.emptyState.querySelector("p").innerHTML = "Use the filters above to search for cabin crew assignments<br />by flight. Enter flight details to get started.";
                        return;
                    }

                    if (!rows.length) {
                        el.emptyState.classList.remove("d-none");
                        el.summarySection.classList.add("d-none");
                        el.emptyState.querySelector("h3").textContent = "No Results Found";
                        el.emptyState.querySelector("p").innerHTML = "No cabin crew assignments matched your filters.<br />Try another Flight No, date, or board point.";
                        return;
                    }

                    el.emptyState.classList.add("d-none");
                    el.summarySection.classList.remove("d-none");
                    renderSummary();
                }

                el.filterSearchBtn.addEventListener("click", function () {
                    state.filterFlightNo = el.filterFlightNo.value.trim();
                    state.filterDate = normalizeDateInput(el.filterDate.value);
                    state.filterBoardPoint = el.filterBoardPoint.value.trim();
                    state.summaryPage = 1;
                    state.summarySearch = "";
                    el.summarySearch.value = "";
                    state.searched = true;
                    renderView();
                });

                el.summarySearch.addEventListener("input", function () {
                    state.summarySearch = this.value.trim();
                    state.summaryPage = 1;
                    renderView();
                });

                el.summaryEntries.addEventListener("change", function () {
                    state.summaryEntries = parseInt(this.value, 10);
                    state.summaryPage = 1;
                    renderView();
                });

                el.summaryPrev.addEventListener("click", function () {
                    if (state.summaryPage <= 1) return;
                    state.summaryPage -= 1;
                    renderSummary();
                });

                el.summaryNext.addEventListener("click", function () {
                    const total = filterFlights().length;
                    const pages = Math.max(1, Math.ceil(total / state.summaryEntries));
                    if (state.summaryPage >= pages) return;
                    state.summaryPage += 1;
                    renderSummary();
                });

                el.crewEntries.addEventListener("change", function () {
                    state.crewEntries = parseInt(this.value, 10);
                    state.crewPage = 1;
                    renderCrewDetails();
                });

                if (el.crewSearchInput) {
                    el.crewSearchInput.addEventListener("input", function () {
                        state.crewSearch = this.value.trim();
                        state.crewPage = 1;
                        renderCrewDetails();
                    });
                }

                el.crewPrev.addEventListener("click", function () {
                    if (state.crewPage <= 1) return;
                    state.crewPage -= 1;
                    renderCrewDetails();
                });

                el.crewNext.addEventListener("click", function () {
                    const total = tableStateRows(mockCrewByFlight[state.selectedFlight] || [], state.crewSearch, state.crewSort).length;
                    const pages = Math.max(1, Math.ceil(total / state.crewEntries));
                    if (state.crewPage >= pages) return;
                    state.crewPage += 1;
                    renderCrewDetails();
                });

                el.snyEntries.addEventListener("change", function () {
                    state.snyEntries = parseInt(this.value, 10);
                    state.snyPage = 1;
                    renderSnyDetails();
                });

                if (el.snySearchInput) {
                    el.snySearchInput.addEventListener("input", function () {
                        state.snySearch = this.value.trim();
                        state.snyPage = 1;
                        renderSnyDetails();
                    });
                }

                el.snyPrev.addEventListener("click", function () {
                    if (state.snyPage <= 1) return;
                    state.snyPage -= 1;
                    renderSnyDetails();
                });

                el.snyNext.addEventListener("click", function () {
                    const total = tableStateRows(mockSnyByFlight[state.selectedFlight] || [], state.snySearch, state.snySort).length;
                    const pages = Math.max(1, Math.ceil(total / state.snyEntries));
                    if (state.snyPage >= pages) return;
                    state.snyPage += 1;
                    renderSnyDetails();
                });

                el.backBtn.addEventListener("click", function () {
                    state.selectedFlight = "";
                    renderView();
                });

                document.querySelectorAll(".cbf-sort").forEach((th) => {
                    th.addEventListener("click", function () {
                        const table = th.dataset.table;
                        const key = th.dataset.key;
                        if (table === "summary") {
                            toggleSort(state.summarySort, key);
                            state.summaryPage = 1;
                            renderSummary();
                        } else if (table === "crew") {
                            toggleSort(state.crewSort, key);
                            state.crewPage = 1;
                            renderCrewDetails();
                        } else {
                            toggleSort(state.snySort, key);
                            state.snyPage = 1;
                            renderSnyDetails();
                        }
                    });
                });

                renderView();
            });
        </script>
    }

