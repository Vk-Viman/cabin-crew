@{
    ViewData["Title"] = "Ground Staff Dashboard";
}

<div class="gsd-page">
    <section class="gsd-hero gsd-card">
        <div>
            <h2>Ground Staff Dashboard</h2>
            <p>Use Incident Reports and Voyage Reports to monitor your assigned flights.</p>
        </div>
        <div class="gsd-badge">Read Only</div>
    </section>

    <section class="gsd-insights-grid">
        <article class="gsd-card gsd-chart-card">
            <div class="gsd-chart-head">
                <div>
                    <h3>Incident Overview</h3>
                    <p>Open and closed incidents across your assigned flights.</p>
                </div>
                <span class="gsd-chip" id="gsdIncidentTotal">0 Incidents</span>
            </div>
            <div class="gsd-chart-wrap">
                <canvas id="gsdIncidentChart" aria-label="Incident overview chart" role="img"></canvas>
            </div>
        </article>

        <article class="gsd-card gsd-chart-card">
            <div class="gsd-chart-head">
                <div>
                    <h3>Voyage Overview</h3>
                    <p>Voyage status summary for the flights assigned to you.</p>
                </div>
                <span class="gsd-chip" id="gsdVoyageTotal">0 Voyages</span>
            </div>
            <div class="gsd-chart-wrap">
                <canvas id="gsdVoyageChart" aria-label="Voyage overview chart" role="img"></canvas>
            </div>
        </article>
    </section>

    <section class="gsd-grid">
        <article class="gsd-card gsd-module">
            <h3>Incident Reports</h3>
            <p>View incidents from flights assigned to you. Search, sort and open details with image gallery.</p>
            <a class="gsd-link" asp-controller="Incidents" asp-action="Index">Open Incident Reports</a>
        </article>

        <article class="gsd-card gsd-module">
            <h3>Voyage Reports</h3>
            <p>View voyage records from your assigned flights with all detailed report sections.</p>
            <a class="gsd-link" asp-controller="Voyage" asp-action="Reports">Open Voyage Reports</a>
        </article>
    </section>

    <section class="gsd-card gsd-assignments">
        <div class="gsd-head">
            <h3>Assigned Flights</h3>
            <span id="gsdAssignedCount" class="gsd-chip">0 Flights</span>
        </div>
        <div id="gsdAssignedList" class="gsd-list"></div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        var charts = [];
        var countEl = document.getElementById("gsdAssignedCount");
        var listEl = document.getElementById("gsdAssignedList");
        var incidentTotalEl = document.getElementById("gsdIncidentTotal");
        var voyageTotalEl = document.getElementById("gsdVoyageTotal");
        var incidentCanvas = document.getElementById("gsdIncidentChart");
        var voyageCanvas = document.getElementById("gsdVoyageChart");
        var storedRole = localStorage.getItem("cc_user_role") || "Ground User";

        if (storedRole === "Admin") {
        window.location.href = "@Url.Action("Index", "Home")";
        return;
        }

        var flights = [];
        try {
        var raw = localStorage.getItem("cc_assigned_flights") || "[]";
        var parsed = JSON.parse(raw);
        flights = Array.isArray(parsed)
        ? parsed.map(function (f) { return String(f || "").trim().toUpperCase(); }).filter(Boolean)
        : [];
        } catch (_error) {
        flights = [];
        }

        var incidentData = [
        { flightNo: "UL101", status: "OPEN", category: "Safety" },
        { flightNo: "UL205", status: "CLOSED", category: "Service" },
        { flightNo: "UL504", status: "CLOSED", category: "Passenger" },
        { flightNo: "UL504", status: "OPEN", category: "Safety" }
        ].filter(function (item) {
        return flights.indexOf(item.flightNo) !== -1;
        });

        var voyageData = [
        { flightNo: "UL101", status: "On Time" },
        { flightNo: "UL205", status: "Delayed" },
        { flightNo: "UL504", status: "On Time" }
        ].filter(function (item) {
        return flights.indexOf(item.flightNo) !== -1;
        });

        function countBy(items, key, values) {
        return values.map(function (value) {
        return items.filter(function (item) {
        return item[key] === value;
        }).length;
        });
        }

        function destroyCharts() {
        charts.forEach(function (chart) {
        if (chart && typeof chart.destroy === "function") {
        chart.destroy();
        }
        });
        charts = [];
        }

        function renderCharts() {
        if (typeof Chart === "undefined") return;

        destroyCharts();

        if (incidentTotalEl) {
        incidentTotalEl.textContent = incidentData.length + (incidentData.length === 1 ? " Incident" : " Incidents");
        }

        if (voyageTotalEl) {
        voyageTotalEl.textContent = voyageData.length + (voyageData.length === 1 ? " Voyage" : " Voyages");
        }

        if (incidentCanvas) {
        charts.push(new Chart(incidentCanvas, {
        type: "doughnut",
        data: {
        labels: ["Open", "Closed"],
        datasets: [{
        data: countBy(incidentData, "status", ["OPEN", "CLOSED"]),
        backgroundColor: ["#f59e0b", "#0f1e7d"],
        borderWidth: 0,
        hoverOffset: 8
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: "68%",
        plugins: {
        legend: {
        position: "bottom",
        labels: {
        color: "#4a5565",
        boxWidth: 12,
        boxHeight: 12,
        usePointStyle: true,
        pointStyle: "circle"
        }
        }
        }
        }
        }));
        }

        if (voyageCanvas) {
        charts.push(new Chart(voyageCanvas, {
        type: "bar",
        data: {
        labels: ["On Time", "Delayed"],
        datasets: [{
        label: "Voyages",
        data: countBy(voyageData, "status", ["On Time", "Delayed"]),
        backgroundColor: ["#027499", "#dc2626"],
        borderRadius: 8,
        borderSkipped: false
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false }
        },
        scales: {
        x: {
        grid: { display: false },
        ticks: { color: "#4a5565" }
        },
        y: {
        beginAtZero: true,
        ticks: { precision: 0, color: "#4a5565" },
        grid: { color: "rgba(107,114,128,0.18)" }
        }
        }
        }
        }));
        }
        }

        if (countEl) {
        countEl.textContent = flights.length + (flights.length === 1 ? " Flight" : " Flights");
        }

        if (!listEl) return;

        if (!flights.length) {
        listEl.innerHTML = '<p class="gsd-empty">No assigned flights were found for your profile.</p>';
        renderCharts();
        return;
        }

        listEl.innerHTML = flights.map(function (flightNo) {
        return '<span class="gsd-flight">' + flightNo + '</span>';
        }).join("");

        renderCharts();
        });
    </script>
}

@section Styles {
    <style>
        .gsd-page {
        max-width: 1574px;
        margin: 0 auto;
        color: #1a1a1a;
        font-family: Arial, sans-serif;
        }

        .gsd-card {
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 10px 15px rgba(0, 0, 0, 0.08), 0 4px 6px rgba(0, 0, 0, 0.08);
        margin-bottom: 24px;
        }

        .gsd-insights-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
        }

        .gsd-chart-card {
        padding: 24px;
        min-height: 340px;
        }

        .gsd-chart-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 18px;
        }

        .gsd-chart-head h3 {
        margin: 0;
        font-size: 22px;
        font-weight: 400;
        color: #0f1e7d;
        }

        .gsd-chart-head p {
        margin: 8px 0 0;
        color: #4a5565;
        font-size: 15px;
        line-height: 22px;
        }

        .gsd-chart-wrap {
        position: relative;
        height: 240px;
        }

        .gsd-hero {
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        background: linear-gradient(95deg, #1256b5 0%, #0166bf 35%, #0a7ca5 100%);
        color: #ffffff;
        }

        .gsd-hero h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 400;
        }

        .gsd-hero p {
        margin: 8px 0 0;
        color: #dbeafe;
        font-size: 16px;
        }

        .gsd-badge {
        border-radius: 999px;
        padding: 6px 14px;
        background: rgba(255, 255, 255, 0.16);
        border: 1px solid rgba(255, 255, 255, 0.35);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        white-space: nowrap;
        }

        .gsd-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
        }

        .gsd-module {
        padding: 24px;
        min-height: 220px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        }

        .gsd-module h3 {
        margin: 0;
        font-size: 22px;
        font-weight: 400;
        color: #0f1e7d;
        }

        .gsd-module p {
        margin: 0;
        font-size: 16px;
        line-height: 24px;
        color: #4a5565;
        flex: 1;
        }

        .gsd-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 220px;
        max-width: 100%;
        height: 40px;
        border-radius: 8px;
        background: #0f1e7d;
        color: #ffffff;
        text-decoration: none;
        font-size: 15px;
        font-weight: 700;
        }

        .gsd-assignments {
        padding: 24px;
        }

        .gsd-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
        }

        .gsd-head h3 {
        margin: 0;
        font-size: 22px;
        font-weight: 400;
        }

        .gsd-chip {
        border-radius: 999px;
        padding: 5px 12px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        font-size: 12px;
        font-weight: 700;
        color: #364153;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        }

        .gsd-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        }

        .gsd-flight {
        border-radius: 999px;
        padding: 6px 14px;
        background: #eff6ff;
        border: 1px solid #bedbff;
        color: #1447e6;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        }

        .gsd-empty {
        margin: 0;
        color: #6b7280;
        font-style: italic;
        }

        @@media (max-width: 900px) {

        .gsd-insights-grid,
        .gsd-grid {
        grid-template-columns: 1fr;
        }

        .gsd-hero {
        flex-direction: column;
        align-items: flex-start;
        }

        .gsd-chart-head {
        flex-direction: column;
        }
        }
    </style>
}