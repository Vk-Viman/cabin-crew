@{
    Layout = null;
    ViewData["Title"] = "Cabin Crew Login";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
            :root {
                --brand-gold: #e8a724;
                --panel-border: rgba(232, 167, 36, 0.45);
                --panel-bg: rgba(17, 23, 34, 0.30);
                --field-bg: rgba(30, 35, 45, 0.9);
                --text-main: #f1f3f5;
                --text-subtle: #cfd3d9;
                --text-muted: #aeb4bf;
                --glow: 0 8px 24px rgba(0, 0, 0, 0.25);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                color: var(--text-main);
                font-family: "Segoe UI", "Trebuchet MS", "Gill Sans", sans-serif;
                background: #0c111a;
                overflow: hidden;
            }

            .login-page {
                position: relative;
                min-height: 100vh;
                padding: 38px 42px;
                display: grid;
                grid-template-columns: 1fr minmax(380px, 440px);
                gap: 24px;
                align-items: center;
                background-image: linear-gradient(110deg, rgba(11, 16, 24, 0.68) 0%, rgba(11, 16, 24, 0.34) 44%, rgba(11, 16, 24, 0.7) 100%), url('@Url.Content("~/images/Image.jpeg")');
                background-size: cover;
                background-position: center;
            }

            .login-page::after {
                content: "";
                position: absolute;
                inset: 0;
                pointer-events: none;
                background: radial-gradient(circle at 18% 72%, rgba(232, 167, 36, 0.2), transparent 34%), radial-gradient(circle at 76% 18%, rgba(23, 90, 189, 0.2), transparent 30%);
            }

            .brand-column,
            .panel-column {
                position: relative;
                z-index: 1;
            }

            .brand-wrap {
                max-width: 620px;
                margin-left: 100px;
                animation: fadeUp 700ms ease-out;
            }

            .brand-top {
                display: flex;
                align-items: center;
                gap: 16px;
                margin-bottom: 34px;
            }

            .brand-icon {
                width: 62px;
                height: 62px;
                border-radius: 12px;
                background: var(--brand-gold);
                display: grid;
                place-items: center;
                box-shadow: var(--glow);
            }

            .brand-icon svg {
                width: 34px;
                height: 34px;
                color: #fff;
            }

            .brand-title {
                margin: 0;
                letter-spacing: 1.5px;
                font-size: 42px;
                font-weight: 300;
                line-height: 1.04;
                text-transform: uppercase;
                max-width: 520px;
            }

            .brand-lines {
                margin: 0;
                font-size: 40px;
                letter-spacing: 2px;
                font-weight: 300;
                text-transform: uppercase;
                line-height: 1.08;
                color: rgba(244, 246, 248, 0.94);
            }

            .brand-sub {
                margin: 8px 0 0;
                color: var(--brand-gold);
                font-size: 26px;
                letter-spacing: 1px;
                text-transform: uppercase;
                font-weight: 500;
            }

            .brand-accent {
                margin-top: 24px;
                width: 104px;
                height: 5px;
                border-radius: 999px;
                background: var(--brand-gold);
            }

            .panel-column {
                display: flex;
                justify-content: center;
                animation: fadeUp 900ms ease-out;
            }

            .login-panel {
                width: min(440px, 100%);
                border: 1px solid var(--panel-border);
                border-radius: 18px;
                background: var(--panel-bg);
                backdrop-filter: blur(4px);
                box-shadow: var(--glow);
                padding: 34px 34px 30px;
            }

            .panel-lock {
                width: 66px;
                height: 66px;
                border-radius: 14px;
                margin: 0 auto 16px;
                background: var(--brand-gold);
                display: grid;
                place-items: center;
            }

            .panel-lock svg {
                width: 32px;
                height: 32px;
                color: #fff;
            }

            .panel-title {
                margin: 0;
                text-align: center;
                font-size: 50px;
                font-weight: 300;
                color: rgba(245, 247, 249, 0.95);
                letter-spacing: 0.4px;
            }

            .panel-subtitle {
                margin: 8px 0 28px;
                text-align: center;
                color: var(--text-subtle);
                font-size: 25px;
                font-weight: 300;
            }

            .field {
                margin-bottom: 16px;
            }

            .field label {
                display: block;
                margin-bottom: 8px;
                font-size: 24px;
                color: rgba(232, 236, 243, 0.92);
            }

            .field-wrap {
                position: relative;
            }

            .field-wrap svg {
                width: 18px;
                height: 18px;
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--brand-gold);
                opacity: 0.95;
            }

            .field input {
                width: 100%;
                height: 44px;
                border-radius: 10px;
                border: 1px solid rgba(255, 255, 255, 0.18);
                background: var(--field-bg);
                color: #fff;
                font-size: 15px;
                padding: 0 12px 0 40px;
                outline: none;
                transition: border-color 150ms ease;
            }

            .field input::placeholder {
                color: var(--text-muted);
            }

            .field input:focus {
                border-color: var(--brand-gold);
            }

            .field select {
                width: 100%;
                height: 44px;
                border-radius: 10px;
                border: 1px solid rgba(255, 255, 255, 0.18);
                background: var(--field-bg);
                color: #fff;
                font-size: 15px;
                padding: 0 12px;
                outline: none;
                transition: border-color 150ms ease;
            }

            .field select:focus {
                border-color: var(--brand-gold);
            }

            .submit-btn {
                margin-top: 18px;
                width: 100%;
                border: none;
                border-radius: 12px;
                height: 44px;
                background: var(--brand-gold);
                color: #fff;
                font-size: 22px;
                letter-spacing: 0.7px;
                text-transform: uppercase;
                cursor: pointer;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                transition: transform 120ms ease, filter 120ms ease;
            }

            .submit-btn:hover {
                filter: brightness(1.03);
                transform: translateY(-1px);
            }

            .footer-note {
                position: absolute;
                z-index: 1;
                left: 50%;
                transform: translateX(-50%);
                bottom: 18px;
                color: rgba(218, 222, 227, 0.75);
                font-size: 14px;
                letter-spacing: 0.3px;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(16px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@media (max-width: 980px) {
                body {
                    overflow: auto;
                }

                .login-page {
                    grid-template-columns: 1fr;
                    align-items: start;
                    padding: 24px;
                }

                .brand-wrap {
                    margin: 16px auto 0;
                }

                .brand-title,
                .brand-lines {
                    font-size: 46px;
                }

                .brand-sub {
                    font-size: 20px;
                }

                .panel-column {
                    margin-top: 6px;
                    padding-bottom: 56px;
                }

                .panel-title {
                    font-size: 42px;
                }

                .panel-subtitle {
                    font-size: 20px;
                }

                .field label {
                    font-size: 20px;
                }

                .submit-btn {
                    font-size: 18px;
                }

                .footer-note {
                    position: static;
                    transform: none;
                    margin-top: 8px;
                    text-align: center;
                }
            }
    </style>
</head>

<body>
    <main class="login-page">
        <section class="brand-column">
            <div class="brand-wrap">
                <div class="brand-top">
                    <div class="brand-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 14.5 10 13l6-6a2.4 2.4 0 0 1 3.4 3.4l-6 6L12 23l-2.2-6.8L3 14.5Z"
                                  stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                            <path d="M13 10.6 9.4 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                        </svg>
                    </div>
                    <div>
                        <p class="brand-lines">SriLankan Airlines</p>
                        <p class="brand-sub">Cabin Crew Operations</p>
                    </div>
                </div>

                <h1 class="brand-title">Cabin Crew Operations</h1>
                <div class="brand-accent"></div>
            </div>
        </section>

        <section class="panel-column">
            <div class="login-panel">
                <div class="panel-lock" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="10" width="16" height="10" rx="2" stroke="currentColor" stroke-width="1.8" />
                        <path d="M8 10V7.4A4 4 0 0 1 12 3.5a4 4 0 0 1 4 3.9V10" stroke="currentColor" stroke-width="1.8"
                              stroke-linecap="round" />
                    </svg>
                </div>

                <h2 class="panel-title">Welcome Back</h2>
                <p class="panel-subtitle">Sign in to continue to your dashboard</p>

                <form id="loginForm" autocomplete="off">

                    <div class="field">
                        <label for="username">Username</label>
                        <div class="field-wrap">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.8" />
                                <path d="M5.7 19c.7-3.2 3.3-5 6.3-5 3 0 5.6 1.8 6.3 5" stroke="currentColor"
                                      stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                            <input id="username" name="username" type="text" placeholder="Enter your username" />
                        </div>
                    </div>

                    <div class="field">
                        <label for="password">Password</label>
                        <div class="field-wrap">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="5" y="10" width="14" height="10" rx="2" stroke="currentColor"
                                      stroke-width="1.8" />
                                <path d="M8.2 10V7.6A3.8 3.8 0 0 1 12 3.8a3.8 3.8 0 0 1 3.8 3.8V10"
                                      stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                            <input id="password" name="password" type="password" placeholder="Enter your password" />
                        </div>
                    </div>

                    <div class="field">
                        <label for="role">User Type</label>
                        <select id="role" name="role">
                            <option value="Admin" selected>Admin</option>
                            <option value="Ground User">Ground User</option>
                        </select>
                    </div>

                    <button class="submit-btn" type="submit">
                        Sign In
                        <span aria-hidden="true">→</span>
                    </button>
                </form>
            </div>
        </section>

        <div class="footer-note">© 2026 SriLankan Airlines. All rights reserved.</div>
    </main>

    <script>
            document.getElementById("loginForm")?.addEventListener("submit", function (event) {
                event.preventDefault();
                var usernameInput = document.getElementById("username");
                var roleInput = document.getElementById("role");
                var rawName = usernameInput ? usernameInput.value.trim() : "";
                var name = rawName || "John Doe";
                var role = roleInput ? roleInput.value : "Ground User";
                var normalizedRole = role === "Admin" ? "Admin" : "Ground User";

                function resolveAssignedFlights(userName) {
                    var lookup = {
                        "ground1": ["UL101", "UL504"],
                        "ground2": ["UL205"],
                        "ops.ground": ["UL101", "UL205"]
                    };

                    var key = String(userName || "").trim().toLowerCase();
                    var flights = lookup[key] || ["UL205"];
                    return flights.map(function (flightNo) {
                        return String(flightNo || "").toUpperCase();
                    });
                }

                localStorage.setItem("cc_user_name", name);
                localStorage.setItem("cc_user_role", normalizedRole);

                if (normalizedRole === "Ground User") {
                    localStorage.setItem("cc_assigned_flights", JSON.stringify(resolveAssignedFlights(name)));
                } else {
                    localStorage.removeItem("cc_assigned_flights");
                }

                window.location.href = normalizedRole === "Ground User"
                    ? "@Url.Action("GroundDashboard", "Home")"
                    : "@Url.Action("Index", "Home")";
            });
    </script>
</body>

</html>
