@{
    ViewData["Title"] = "Incident Reports";
}

<div class="ir-page">
    <section id="irSearchCard" class="ir-card ir-search-card">
        <form id="incidentSearchForm" class="ir-search-form">
            <div class="ir-form-row-inline">
                <div class="ir-form-field">
                    <label for="flightNo">Flight No</label>
                    <input id="flightNo" type="text" placeholder="ul" />
                </div>

                <div class="ir-form-field">
                    <label for="flightDate">Flight Date (Local)</label>
                    <div class="ir-date-input-wrapper">
                        <input id="flightDate" type="text" placeholder="DD/MM/YY" />
                        <span class="ir-date-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="3.5" y="5" width="17" height="15.5" rx="2" stroke="currentColor"
                                      stroke-width="1.6" />
                                <path d="M3.5 9h17" stroke="currentColor" stroke-width="1.6" />
                                <path d="M8 3.5v3M16 3.5v3" stroke="currentColor" stroke-width="1.6"
                                      stroke-linecap="round" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div class="ir-form-field">
                    <label for="boardPoint">Board Point</label>
                    <input id="boardPoint" type="text" placeholder="cmb" />
                </div>

                <button type="submit" class="ir-btn-search-inline">
                    <span class="ir-search-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8" />
                            <path d="M20 20l-3.4-3.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                        </svg>
                    </span>
                    <span>Search</span>
                </button>
            </div>
        </form>
    </section>

    <section id="incidentEmptyState" class="ir-card ir-state">
        <div class="ir-empty-state">
            <div class="ir-empty-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                    d="M18.1 15 11.44 3.33a1.67 1.67 0 0 0-2.9 0L1.87 15a1.67 1.67 0 0 0 1.46 2.5h13.34A1.67 1.67 0 0 0 18.1 15Z"
                    stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M10 7.5v3.33" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    <circle cx="10" cy="14.15" r="0.7" fill="currentColor" />
                </svg>
            </div>
            <h3 class="ir-empty-title">Ready to Search</h3>
            <p class="ir-empty-text">Use the filters above to search for incident reports by flight.<br />Enter flight
                details to get started.</p>
            </div>
        </section>

        <section id="incidentTableState" class="ir-card ir-state d-none">
            <div class="ir-table-toolbar">
                <div class="ir-toolbar-left">
                    <span>Show</span>
                    <select id="incidentEntriesSelect">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <span>entries</span>
                    <span id="incidentRecordBadge" class="ir-badge">0 records</span>
                </div>

                <div class="ir-toolbar-search">
                    <span class="ir-toolbar-search-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8" />
                            <path d="M20 20l-3.4-3.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input id="incidentSearchInput" type="text" placeholder="Search Incidents" />
                </div>
            </div>

            <div class="ir-table-wrap">
                <table class="ir-table">
                    <thead>
                        <tr>
                            <th data-sort-key="flightDate">Flight Date <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="boardPoint">Board Point <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="flightNo">Flight No <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="description">Description <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="paxName">PAX Name <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="paxSeat">PAX Seat <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="responsibleBy">Responsible By <span class="ir-sort">⇅</span></th>
                            <th data-sort-key="status">Status <span class="ir-sort">⇅</span></th>
                        </tr>
                    </thead>
                    <tbody id="incidentTableBody"></tbody>
                </table>
            </div>

            <div class="ir-table-footer">
                <span id="incidentPagingInfo">Showing 0 to 0 of 0 entries</span>
                <div class="ir-pager-btns">
                    <button id="incidentPrevBtn" type="button">Previous</button>
                    <button id="incidentPageBtn" type="button" class="active">1</button>
                    <button id="incidentNextBtn" type="button">Next</button>
                </div>
            </div>
        </section>

        <section id="incidentDetailState" class="ir-state d-none">
            <button id="backToListBtn" type="button" class="ir-back-btn">Back to Incident Reports</button>

            <article class="ir-card ir-summary-card">
                <div class="ir-summary-icon" aria-hidden="true">!</div>

                <div class="ir-summary-main">
                    <p id="detailFlightNo" class="ir-summary-flight">Flight UL101</p>
                    <p id="detailRoute" class="ir-summary-route">CMB → LHR</p>
                </div>

                <div class="ir-summary-meta">
                    <div class="ir-meta-item">
                        <span class="ir-summary-label">Date</span>
                        <p id="detailDate">2025-11-15</p>
                    </div>
                    <div class="ir-meta-item">
                        <span class="ir-summary-label">Category</span>
                        <p id="detailCategory">Safety</p>
                    </div>
                    <div class="ir-meta-item">
                        <span class="ir-summary-label">PNR Ticket</span>
                        <p id="detailTicket" class="ir-summary-pill">ABC123</p>
                    </div>
                    <div class="ir-meta-item">
                        <span class="ir-summary-label">Seat No</span>
                        <p id="detailSeat" class="ir-summary-pill">12A</p>
                    </div>
                </div>
            </article>

            <div class="ir-detail-grid">
                <article class="ir-card">
                    <header class="ir-card-header-title">Incident Description</header>
                    <div class="ir-card-content">
                        <label>Description</label>
                        <p id="detailDescription">Passenger medical emergency</p>
                        <label>Additional Details</label>
                        <p id="detailAdditional">Passenger experienced chest pain during flight.</p>
                    </div>
                </article>

                <article class="ir-card">
                    <header class="ir-card-header-title">Assignment &amp; Reporting</header>
                    <div class="ir-assignment-grid">
                        <div>
                            <label>Reported By</label>
                            <p id="detailResponsible">CCM-456</p>
                        </div>
                        <div>
                            <label>Assigned By</label>
                            <p>ADM-001</p>
                        </div>
                        <div>
                            <label>Assigned Inspector</label>
                            <p id="detailAssignedInspector">Not assigned</p>
                        </div>
                    </div>
                </article>

                <article class="ir-card">
                    <header class="ir-card-header-title">Attached Images</header>
                    <div class="ir-card-content">
                        <button id="imageGalleryBtn" type="button" class="ir-gallery-btn">View Image Gallery (3
                            images)</button>
                            <p class="ir-gallery-hint">Click to open the attached incident images.</p>
                        </div>
                    </article>

                    <article id="incidentActionsCard" class="ir-card">
                        <header class="ir-card-header-title">Inspection Comments</header>
                        <div class="ir-comments-grid">
                            <div class="ir-field">
                                <label for="commentTitle">Comment Title</label>
                                <input id="commentTitle" type="text" placeholder="Enter comment title..." />
                            </div>
                            <div class="ir-field">
                                <label for="commentStatus">Status</label>
                                <select id="commentStatus">
                                    <option value="">Select status...</option>
                                    <option>OPEN</option>
                                    <option>CLOSED</option>
                                </select>
                            </div>
                            <div class="ir-field ir-field-full">
                                <label for="commentBody">Comment</label>
                                <textarea id="commentBody" rows="3" placeholder="Enter your inspection comments..."></textarea>
                            </div>
                            <div class="ir-comment-actions">
                                <button id="assignStaffBtn" type="button" class="ir-btn-secondary">Assign</button>
                                <button id="submitCommentBtn" type="button" class="ir-btn-primary">Submit</button>
                            </div>
                            <p id="commentSubmitFeedback" class="ir-comment-feedback" aria-live="polite"></p>
                            <div class="ir-comment-history">
                                <h4>Submitted Comments</h4>
                                <div id="commentHistoryList" class="ir-comment-history-list">
                                    <p class="ir-comment-history-empty">No comments submitted yet.</p>
                                </div>
                            </div>
                        </div>
                    </article>
                </div>

                <div id="imageGalleryModal" class="ir-gallery-modal d-none" role="dialog" aria-modal="true"
                     aria-labelledby="imageGalleryTitle">
                    <div class="ir-gallery-backdrop" data-gallery-close></div>
                    <div class="ir-gallery-panel">
                        <div class="ir-gallery-header">
                            <h4 id="imageGalleryTitle">Incident Image Gallery</h4>
                            <button type="button" id="imageGalleryCloseBtn" class="ir-gallery-close"
                                    aria-label="Close gallery">×</button>
                        </div>
                        <div class="ir-gallery-grid">
                            <figure class="ir-gallery-item">
                                <img alt="Incident image 1"
                                     src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='520' viewBox='0 0 800 520'><rect width='800' height='520' rx='24' fill='%23dbeafe'/><rect x='70' y='74' width='660' height='372' rx='18' fill='%230f1e7d'/><circle cx='170' cy='160' r='42' fill='%23ffffff' opacity='0.18'/><path d='M110 380c84-108 160-124 242-40 60 62 102 98 150 106 64 11 112-15 188-84v114H110z' fill='%230266a3'/><path d='M215 272h132l64 72-180 2z' fill='%23ffffff' opacity='0.7'/></svg>" />
                                <figcaption>Passenger emergency scene</figcaption>
                            </figure>
                            <figure class="ir-gallery-item">
                                <img alt="Incident image 2"
                                     src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='520' viewBox='0 0 800 520'><rect width='800' height='520' rx='24' fill='%23eef2ff'/><rect x='64' y='64' width='672' height='392' rx='18' fill='%23272727'/><rect x='104' y='102' width='240' height='156' rx='16' fill='%230a7ca5'/><rect x='374' y='102' width='292' height='64' rx='12' fill='%23ffffff' opacity='0.18'/><rect x='374' y='184' width='214' height='40' rx='10' fill='%23ffffff' opacity='0.18'/><rect x='374' y='236' width='160' height='40' rx='10' fill='%23ffffff' opacity='0.18'/><rect x='104' y='286' width='562' height='132' rx='16' fill='%23e5e7eb'/></svg>" />
                                <figcaption>Cabin report documentation</figcaption>
                            </figure>
                            <figure class="ir-gallery-item">
                                <img alt="Incident image 3"
                                     src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='520' viewBox='0 0 800 520'><rect width='800' height='520' rx='24' fill='%23ecfeff'/><rect x='72' y='72' width='656' height='376' rx='20' fill='%23016b94'/><circle cx='210' cy='184' r='54' fill='%23ffffff' opacity='0.2'/><circle cx='570' cy='182' r='54' fill='%23ffffff' opacity='0.2'/><rect x='184' y='300' width='432' height='34' rx='17' fill='%23ffffff' opacity='0.35'/><rect x='232' y='258' width='336' height='20' rx='10' fill='%23ffffff' opacity='0.35'/></svg>" />
                                <figcaption>Follow-up evidence</figcaption>
                            </figure>
                        </div>
                    </div>
                </div>

                <div id="staffAssignModal" class="ir-staff-modal d-none" role="dialog" aria-modal="true"
                     aria-labelledby="staffAssignTitle">
                    <div class="ir-gallery-backdrop" data-staff-close></div>
                    <div class="ir-staff-panel">
                        <div class="ir-gallery-header">
                            <h4 id="staffAssignTitle">Assign Staff</h4>
                            <button type="button" id="staffAssignCloseBtn" class="ir-gallery-close"
                                    aria-label="Close staff search">×</button>
                        </div>
                        <div class="ir-staff-search-row">
                            <div class="ir-field ir-field-full">
                                <label for="staffNumberInput">Staff Number</label>
                                <input id="staffNumberInput" type="text" placeholder="Enter staff number..." />
                            </div>
                            <button id="staffSearchBtn" type="button" class="ir-btn-primary ir-staff-search-btn">Search</button>
                        </div>
                        <div id="staffSearchResults" class="ir-staff-results">
                            <p class="ir-staff-placeholder">Enter a staff number and search to find a matching staff member.</p>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        @section Scripts {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const sampleRows = [
                        {
                            flightDate: "2025-11-15",
                            boardPoint: "CMB",
                            flightNo: "UL101",
                            description: "Passenger medical emergency",
                            paxName: "John Smith",
                            paxSeat: "12A",
                            responsibleBy: "CCM-456",
                            status: "OPEN",
                            route: "CMB → LHR",
                            category: "Safety",
                            ticket: "ABC123",
                            assignedInspector: "ADM-001",
                            additional: "Passenger experienced chest pain during flight. First aid was provided by cabin crew and doctor onboard."
                        },
                        {
                            flightDate: "2025-11-16",
                            boardPoint: "CMB",
                            flightNo: "UL205",
                            description: "Unruly passenger behavior",
                            paxName: "Jane Doe",
                            paxSeat: "24B",
                            responsibleBy: "CCM-789",
                            status: "CLOSED",
                            route: "CMB → SIN",
                            category: "Service",
                            ticket: "JKL258",
                            assignedInspector: "INS-014",
                            additional: "Passenger repeatedly ignored crew instructions. Incident was de-escalated and documented."
                        },
                        {
                            flightDate: "2025-11-20",
                            boardPoint: "CMB",
                            flightNo: "UL504",
                            description: "Cabin baggage compliance issue",
                            paxName: "Lily Thomas",
                            paxSeat: "30A",
                            responsibleBy: "CCM-852",
                            status: "OPEN",
                            route: "CMB → KUL",
                            category: "Compliance",
                            ticket: "MNO701",
                            assignedInspector: "ADM-001",
                            additional: "Overhead baggage was not secured during taxi. Cabin crew corrected the issue before takeoff."
                        }
                    ];

                    const state = {
                        selected: null,
                        searched: false,
                        searchTerm: "",
                        page: 1,
                        pageSize: 10,
                        sort: { key: "flightDate", dir: "desc" },
                        assignedStaff: null,
                        commentStore: {}
                    };

                    const el = {
                        searchCard: document.getElementById("irSearchCard"),
                        searchForm: document.getElementById("incidentSearchForm"),
                        flightNo: document.getElementById("flightNo"),
                        flightDate: document.getElementById("flightDate"),
                        boardPoint: document.getElementById("boardPoint"),
                        empty: document.getElementById("incidentEmptyState"),
                        table: document.getElementById("incidentTableState"),
                        detail: document.getElementById("incidentDetailState"),
                        entries: document.getElementById("incidentEntriesSelect"),
                        tableSearch: document.getElementById("incidentSearchInput"),
                        tableBody: document.getElementById("incidentTableBody"),
                        badge: document.getElementById("incidentRecordBadge"),
                        pagingInfo: document.getElementById("incidentPagingInfo"),
                        prev: document.getElementById("incidentPrevBtn"),
                        pageBtn: document.getElementById("incidentPageBtn"),
                        next: document.getElementById("incidentNextBtn"),
                        back: document.getElementById("backToListBtn"),
                        gallery: document.getElementById("imageGalleryBtn"),
                        galleryModal: document.getElementById("imageGalleryModal"),
                        galleryClose: document.getElementById("imageGalleryCloseBtn"),
                        assignBtn: document.getElementById("assignStaffBtn"),
                        submitCommentBtn: document.getElementById("submitCommentBtn"),
                        commentTitle: document.getElementById("commentTitle"),
                        commentStatus: document.getElementById("commentStatus"),
                        commentBody: document.getElementById("commentBody"),
                        commentFeedback: document.getElementById("commentSubmitFeedback"),
                        commentHistoryList: document.getElementById("commentHistoryList"),
                        staffModal: document.getElementById("staffAssignModal"),
                        staffClose: document.getElementById("staffAssignCloseBtn"),
                        staffInput: document.getElementById("staffNumberInput"),
                        staffSearchBtn: document.getElementById("staffSearchBtn"),
                        staffResults: document.getElementById("staffSearchResults"),
                        incidentActionsCard: document.getElementById("incidentActionsCard"),
                        detailFlightNo: document.getElementById("detailFlightNo"),
                        detailRoute: document.getElementById("detailRoute"),
                        detailDate: document.getElementById("detailDate"),
                        detailCategory: document.getElementById("detailCategory"),
                        detailTicket: document.getElementById("detailTicket"),
                        detailSeat: document.getElementById("detailSeat"),
                        detailDescription: document.getElementById("detailDescription"),
                        detailAdditional: document.getElementById("detailAdditional"),
                        detailResponsible: document.getElementById("detailResponsible"),
                        detailAssignedInspector: document.getElementById("detailAssignedInspector")
                    };

                    const emptyCopy = {
                        readyTitle: "Ready to Search",
                        readyText: "Use the filters above to search for incident reports by flight.<br />Enter flight details to get started.",
                        noResultsTitle: "No Results Found",
                        noResultsText: "No incident reports matched your filters.<br />Try another Flight No, date, or board point."
                    };

                    const rawRole = localStorage.getItem("cc_user_role") || "Ground User";
                    const currentRole = (rawRole === "Admin" || rawRole === "Ground User") ? rawRole : "Ground User";
                    const isGroundUser = currentRole === "Ground User";

                    function getAssignedFlightSet() {
                        if (!isGroundUser) return null;

                        try {
                            const raw = localStorage.getItem("cc_assigned_flights") || "[]";
                            const parsed = JSON.parse(raw);
                            const list = Array.isArray(parsed) ? parsed : [];
                            const normalized = list
                                .map((flightNo) => String(flightNo || "").trim().toUpperCase())
                                .filter(Boolean);
                            return new Set(normalized);
                        } catch (_error) {
                            return new Set();
                        }
                    }

                    const assignedFlightSet = getAssignedFlightSet();

                    const staffDirectory = [
                        { staffNo: "CCM-456", name: "Sarah Johnson", role: "Cabin Crew", team: "Flight Services" },
                        { staffNo: "CCM-789", name: "David Lee", role: "Senior Cabin Crew", team: "Flight Services" },
                        { staffNo: "ADM-001", name: "Maya Fernando", role: "Administrator", team: "Operations" },
                        { staffNo: "INS-014", name: "Ravi Perera", role: "Inspector", team: "Quality Control" }
                    ];

                    function setHidden(node, hidden) {
                        if (node) {
                            node.classList.toggle("d-none", hidden);
                        }
                    }

                    function normalizeDateInput(value) {
                        const raw = (value || "").trim();
                        if (!raw) return "";
                        if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
                        const match = raw.match(/^(\d{1,2})\s*\/\s*(\d{1,2})\s*\/\s*(\d{2}|\d{4})$/);
                        if (!match) return "";
                        const day = String(match[1]).padStart(2, "0");
                        const month = String(match[2]).padStart(2, "0");
                        const year = match[3].length === 2 ? `20${match[3]}` : match[3];
                        return `${year}-${month}-${day}`;
                    }

                    function sortRows(rows) {
                        const sort = state.sort;
                        return [...rows].sort((a, b) => {
                            if (sort.key === "flightDate") {
                                const ad = new Date(a.flightDate);
                                const bd = new Date(b.flightDate);
                                return sort.dir === "asc" ? ad - bd : bd - ad;
                            }

                            const av = String(a[sort.key] ?? "").toLowerCase();
                            const bv = String(b[sort.key] ?? "").toLowerCase();
                            if (av < bv) return sort.dir === "asc" ? -1 : 1;
                            if (av > bv) return sort.dir === "asc" ? 1 : -1;
                            return 0;
                        });
                    }

                    function scopedRows() {
                        if (!isGroundUser) return [...sampleRows];
                        if (!assignedFlightSet || !assignedFlightSet.size) return [];
                        return sampleRows.filter((row) => assignedFlightSet.has(String(row.flightNo || "").toUpperCase()));
                    }

                    function filteredRows() {
                        const text = state.searchTerm.toLowerCase();
                        const filterDate = normalizeDateInput(el.flightDate ? el.flightDate.value : "");

                        const rows = scopedRows().filter((r) => {
                            const byFilter = (
                                (!el.flightNo || !el.flightNo.value || r.flightNo.toLowerCase().includes(el.flightNo.value.trim().toLowerCase())) &&
                                (!el.boardPoint || !el.boardPoint.value || r.boardPoint.toLowerCase().includes(el.boardPoint.value.trim().toLowerCase())) &&
                                (!filterDate || r.flightDate === filterDate)
                            );
                            if (!byFilter) return false;
                            if (!text) return true;
                            return Object.values(r).some((v) => String(v).toLowerCase().includes(text));
                        });

                        return sortRows(rows);
                    }

                    function showState(which) {
                        setHidden(el.empty, true);
                        setHidden(el.table, true);
                        setHidden(el.detail, true);
                        setHidden(el.searchCard, false);

                        if (which === "empty") setHidden(el.empty, false);
                        if (which === "table") setHidden(el.table, false);
                        if (which === "detail") {
                            setHidden(el.searchCard, true);
                            setHidden(el.detail, false);
                        }
                    }

                    function setEmptyStateText(title, text) {
                        if (!el.empty) return;
                        const titleEl = el.empty.querySelector(".ir-empty-title");
                        const textEl = el.empty.querySelector(".ir-empty-text");
                        if (titleEl) titleEl.textContent = title;
                        if (textEl) textEl.innerHTML = text;
                    }

                    function renderStaffResults(staffNo) {
                        if (!el.staffResults) return;
                        const query = (staffNo || "").trim().toLowerCase();
                        if (!query) {
                            el.staffResults.innerHTML = '<p class="ir-staff-placeholder">Enter a staff number and search to find a matching staff member.</p>';
                            return;
                        }

                        const matches = staffDirectory.filter((staff) =>
                            staff.staffNo.toLowerCase().includes(query) ||
                            staff.name.toLowerCase().includes(query)
                        );

                        if (!matches.length) {
                            el.staffResults.innerHTML = `<p class="ir-staff-placeholder">No staff member found for <strong>${staffNo}</strong>.</p>`;
                            return;
                        }

                        el.staffResults.innerHTML = matches.map((staff) => `
                                <button type="button" class="ir-staff-result-card" data-staff-no="${staff.staffNo}" data-staff-name="${staff.name}" data-staff-role="${staff.role}" data-staff-team="${staff.team}">
                                    <div>
                                        <strong>${staff.staffNo}</strong>
                                        <span>${staff.name}</span>
                                    </div>
                                    <div>
                                        <small>${staff.role}</small>
                                        <small>${staff.team}</small>
                                    </div>
                                </button>
                            `).join("");

                        document.querySelectorAll(".ir-staff-result-card").forEach((card) => {
                            const staffNoValue = card.getAttribute("data-staff-no") || "";
                            const nameValue = card.getAttribute("data-staff-name") || "";
                            card.classList.toggle("selected", state.assignedStaff && state.assignedStaff.staffNo === staffNoValue);

                            card.addEventListener("click", function () {
                                state.assignedStaff = {
                                    staffNo: staffNoValue,
                                    name: nameValue,
                                    role: card.getAttribute("data-staff-role") || "",
                                    team: card.getAttribute("data-staff-team") || ""
                                };

                                if (el.detailAssignedInspector) {
                                    el.detailAssignedInspector.textContent = `${state.assignedStaff.staffNo} - ${state.assignedStaff.name}`;
                                }

                                if (el.staffInput) el.staffInput.value = staffNoValue;
                                if (el.staffModal) setHidden(el.staffModal, true);
                                renderStaffResults(staffNoValue);
                            });

                            card.addEventListener("keydown", function (event) {
                                if (event.key === "Enter" || event.key === " ") {
                                    event.preventDefault();
                                    card.click();
                                }
                            });
                        });
                    }

                    function renderDetail(row) {
                        if (!row) return;
                        if (el.detailFlightNo) el.detailFlightNo.textContent = `Flight ${row.flightNo}`;
                        if (el.detailRoute) el.detailRoute.textContent = row.route;
                        if (el.detailDate) el.detailDate.textContent = row.flightDate;
                        if (el.detailCategory) el.detailCategory.textContent = row.category;
                        if (el.detailTicket) el.detailTicket.textContent = row.ticket;
                        if (el.detailSeat) el.detailSeat.textContent = row.paxSeat;
                        if (el.detailDescription) el.detailDescription.textContent = row.description;
                        if (el.detailAdditional) el.detailAdditional.textContent = row.additional;
                        if (el.detailResponsible) el.detailResponsible.textContent = row.responsibleBy;
                        if (el.detailAssignedInspector) {
                            el.detailAssignedInspector.textContent = state.assignedStaff
                                ? `${state.assignedStaff.staffNo} - ${state.assignedStaff.name}`
                                : (row.assignedInspector || "Not assigned");
                        }
                        renderCommentHistory();
                        showState("detail");
                    }

                    function currentIncidentKey() {
                        if (!state.selected) return "";
                        return `${state.selected.flightNo}::${state.selected.flightDate}`;
                    }

                    function getCommentHistory() {
                        const key = currentIncidentKey();
                        return key ? (state.commentStore[key] || []) : [];
                    }

                    function renderCommentHistory() {
                        if (!el.commentHistoryList) return;

                        const comments = getCommentHistory();
                        if (!comments.length) {
                            el.commentHistoryList.innerHTML = '<p class="ir-comment-history-empty">No comments submitted yet.</p>';
                            return;
                        }

                        el.commentHistoryList.innerHTML = comments.map((comment) => `
                                <article class="ir-comment-history-item">
                                    <div class="ir-comment-history-head">
                                        <strong>${comment.title}</strong>
                                        <span class="ir-comment-history-status ${comment.status === "CLOSED" ? "closed" : "open"}">${comment.status}</span>
                                    </div>
                                    <p>${comment.body}</p>
                                    <small>Submitted ${comment.submittedAt}</small>
                                </article>
                            `).join("");
                    }

                    function setCommentFeedback(message, isError) {
                        if (!el.commentFeedback) return;
                        el.commentFeedback.textContent = message;
                        el.commentFeedback.classList.toggle("is-error", Boolean(isError));
                    }

                    function submitComment() {
                        if (!state.selected) {
                            setCommentFeedback("Select an incident before submitting a comment.", true);
                            return;
                        }

                        const title = (el.commentTitle ? el.commentTitle.value : "").trim();
                        const status = el.commentStatus ? el.commentStatus.value : "";
                        const body = (el.commentBody ? el.commentBody.value : "").trim();

                        if (!title || !status || !body) {
                            setCommentFeedback("Fill in Comment Title, Status, and Comment before submitting.", true);
                            return;
                        }

                        const key = currentIncidentKey();
                        const comments = state.commentStore[key] || [];
                        comments.unshift({
                            title,
                            status,
                            body,
                            submittedAt: new Date().toLocaleString()
                        });
                        state.commentStore[key] = comments;

                        if (el.commentTitle) el.commentTitle.value = "";
                        if (el.commentStatus) el.commentStatus.value = "";
                        if (el.commentBody) el.commentBody.value = "";

                        setCommentFeedback("Comment submitted successfully.", false);
                        renderCommentHistory();
                    }

                    function renderTable() {
                        if (!el.entries || !el.tableBody || !el.badge || !el.pagingInfo || !el.pageBtn || !el.prev || !el.next) {
                            return;
                        }

                        const rows = filteredRows();
                        const pageSize = parseInt(el.entries.value || "10", 10);
                        const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                        if (state.page > totalPages) state.page = totalPages;
                        const start = (state.page - 1) * pageSize;
                        const visible = rows.slice(start, start + pageSize);

                        el.badge.textContent = `${rows.length} records`;
                        el.pageBtn.textContent = String(state.page);
                        el.prev.disabled = state.page <= 1;
                        el.next.disabled = state.page >= totalPages;
                        const from = rows.length ? start + 1 : 0;
                        const to = start + visible.length;
                        el.pagingInfo.textContent = `Showing ${from} to ${to} of ${rows.length} entries`;

                        el.tableBody.innerHTML = visible.length
                            ? visible.map((r, i) => `
                                    <tr class="ir-clickable-row" data-flight="${r.flightNo}" data-date="${r.flightDate}">
                                        <td>${r.flightDate}</td>
                                        <td>${r.boardPoint}</td>
                                        <td>${r.flightNo}</td>
                                        <td>${r.description}</td>
                                        <td>${r.paxName}</td>
                                        <td>${r.paxSeat}</td>
                                        <td>${r.responsibleBy}</td>
                                        <td><span class="ir-status ${r.status === "OPEN" ? "ir-status-open" : "ir-status-closed"}">${r.status}</span></td>
                                    </tr>
                                `).join("")
                            : `<tr><td colspan="8" class="ir-empty-row">No matching incident records</td></tr>`;

                        document.querySelectorAll(".ir-clickable-row").forEach((rowEl) => {
                            rowEl.addEventListener("click", function () {
                                const flight = rowEl.getAttribute("data-flight") || "";
                                const date = rowEl.getAttribute("data-date") || "";
                                const row = rows.find((x) => x.flightNo === flight && x.flightDate === date) || null;
                                state.selected = row || null;
                                renderDetail(state.selected);
                            });
                        });
                    }

                    function updateLandingState() {
                        if (!state.searched) {
                            setEmptyStateText(emptyCopy.readyTitle, emptyCopy.readyText);
                            showState("empty");
                            return;
                        }
                        const rows = filteredRows();
                        if (!rows.length) {
                            setEmptyStateText(
                                emptyCopy.noResultsTitle,
                                isGroundUser
                                    ? "No assigned incident reports matched your filters.<br />Try another Flight No, date, or board point."
                                    : emptyCopy.noResultsText
                            );
                            showState("empty");
                            return;
                        }
                        setEmptyStateText(emptyCopy.readyTitle, emptyCopy.readyText);
                        showState("table");
                        renderTable();
                    }

                    if (el.searchForm) {
                        el.searchForm.addEventListener("submit", function (e) {
                            e.preventDefault();
                            state.page = 1;
                            state.searched = true;
                            updateLandingState();
                        });
                    }

                    if (el.tableSearch) {
                        el.tableSearch.addEventListener("input", function () {
                            state.searchTerm = (el.tableSearch.value || "").trim();
                            state.page = 1;
                            renderTable();
                        });
                    }

                    if (el.entries) {
                        el.entries.addEventListener("change", function () {
                            state.page = 1;
                            renderTable();
                        });
                    }

                    if (el.prev) {
                        el.prev.addEventListener("click", function () {
                            if (state.page <= 1) return;
                            state.page -= 1;
                            renderTable();
                        });
                    }

                    if (el.next) {
                        el.next.addEventListener("click", function () {
                            const total = filteredRows().length;
                            const pageSize = parseInt((el.entries && el.entries.value) || "10", 10);
                            const pages = Math.max(1, Math.ceil(total / pageSize));
                            if (state.page >= pages) return;
                            state.page += 1;
                            renderTable();
                        });
                    }

                    if (el.back) {
                        el.back.addEventListener("click", function () {
                            state.selected = null;
                            setEmptyStateText(emptyCopy.readyTitle, emptyCopy.readyText);
                            showState("table");
                            renderTable();
                        });
                    }

                    if (el.gallery) {
                        el.gallery.addEventListener("click", function () {
                            setHidden(el.galleryModal, false);
                        });
                    }

                    if (el.galleryClose) {
                        el.galleryClose.addEventListener("click", function () {
                            setHidden(el.galleryModal, true);
                        });
                    }

                    if (el.galleryModal) {
                        el.galleryModal.addEventListener("click", function (event) {
                            if (event.target && event.target.hasAttribute("data-gallery-close")) {
                                setHidden(el.galleryModal, true);
                            }
                        });
                    }

                    if (el.assignBtn) {
                        el.assignBtn.addEventListener("click", function () {
                            if (el.staffInput) el.staffInput.value = "";
                            renderStaffResults("");
                            setHidden(el.staffModal, false);
                            if (el.staffInput) el.staffInput.focus();
                        });
                    }

                    if (el.submitCommentBtn) {
                        el.submitCommentBtn.addEventListener("click", function () {
                            if (isGroundUser) {
                                setCommentFeedback("Ground User has read-only access for incidents.", true);
                                return;
                            }
                            submitComment();
                        });
                    }

                    if (el.staffClose) {
                        el.staffClose.addEventListener("click", function () {
                            setHidden(el.staffModal, true);
                        });
                    }

                    if (el.staffModal) {
                        el.staffModal.addEventListener("click", function (event) {
                            if (event.target && event.target.hasAttribute("data-staff-close")) {
                                setHidden(el.staffModal, true);
                            }
                        });
                    }

                    if (el.staffSearchBtn && !isGroundUser) {
                        el.staffSearchBtn.addEventListener("click", function () {
                            renderStaffResults(el.staffInput ? el.staffInput.value : "");
                        });
                    }

                    if (el.staffInput && !isGroundUser) {
                        el.staffInput.addEventListener("keydown", function (event) {
                            if (event.key === "Enter") {
                                event.preventDefault();
                                renderStaffResults(el.staffInput ? el.staffInput.value : "");
                            }
                        });
                    }

                    if (isGroundUser) {
                        if (el.incidentActionsCard) {
                            el.incidentActionsCard.classList.add("d-none");
                        }
                        if (el.assignBtn) el.assignBtn.classList.add("d-none");
                        if (el.submitCommentBtn) el.submitCommentBtn.classList.add("d-none");
                    }

                    document.querySelectorAll(".ir-table th[data-sort-key]").forEach((header) => {
                        header.addEventListener("click", function () {
                            const key = header.getAttribute("data-sort-key") || "flightDate";
                            if (state.sort.key === key) {
                                state.sort.dir = state.sort.dir === "asc" ? "desc" : "asc";
                            } else {
                                state.sort.key = key;
                                state.sort.dir = "asc";
                            }
                            state.page = 1;
                            renderTable();
                        });
                    });

                    showState("empty");
                });
            </script>
        }

