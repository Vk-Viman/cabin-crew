<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cabin_Crew</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Cabin_Crew.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Top bar -->
    <header class="topbar">
        <div class="topbar-left">
            <span class="page-title">@ViewData["Title"]</span>
        </div>
        <div class="topbar-right ms-auto d-flex align-items-center">
            <div class="text-end me-3">
                <div class="user-name">John Doe</div>
                <div class="user-role">Crew Admin</div>
            </div>
            <div class="avatar bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center">JD</div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-logo-container">
            <a class="d-flex align-items-center justify-content-center text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="@Url.Content("~/images/cabinops-logo.png")" alt="CabinOps" class="sidebar-logo" />
            </a>
        </div>

        <nav class="nav flex-column" aria-label="Main navigation">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="nav-icon">🏠</i>
                <span>Dashboard</span>
            </a>

            <div class="nav-section">
                <div class="nav-section-title">INCIDENT MANAGEMENT</div>
                <a class="nav-link" asp-area="" asp-controller="Incidents" asp-action="Index">
                    <i class="nav-icon">⚠️</i>
                    <span>Incident Reports</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">VOYAGE MANAGEMENT</div>
                <a class="nav-link" asp-area="" asp-controller="Voyage" asp-action="Reports">
                    <i class="nav-icon">📄</i>
                    <span>Voyage Reports</span>
                </a>
                <a class="nav-link" asp-area="" asp-controller="Voyage" asp-action="Unsubmitted">
                    <i class="nav-icon">⭕</i>
                    <span>Unsubmitted Reports</span>
                </a>
                <a class="nav-link" asp-area="" asp-controller="Voyage" asp-action="ManualEntry">
                    <i class="nav-icon">✏️</i>
                    <span>Manual Voyage Entry</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">CREW MANAGEMENT</div>
                <a class="nav-link" asp-area="" asp-controller="Crew" asp-action="Tracker">
                    <i class="nav-icon">📱</i>
                    <span>CabinOps iPad Tracker</span>
                </a>
                <a class="nav-link" asp-area="" asp-controller="Crew" asp-action="Flight">
                    <i class="nav-icon">👥</i>
                    <span>Cabin Crew by Flight</span>
                </a>
                <a class="nav-link" asp-area="" asp-controller="Crew" asp-action="Recovery">
                    <i class="nav-icon">✍️</i>
                    <span>Signature Recovery</span>
                </a>
                <a class="nav-link" asp-area="" asp-controller="Crew" asp-action="Details">
                    <i class="nav-icon">👤</i>
                    <span>Update Pilot Details</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">REPORTS</div>
                <a class="nav-link" asp-area="" asp-controller="Reports" asp-action="Index">
                    <i class="nav-icon">📊</i>
                    <span>Generate Reports</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">CONFIGURATION</div>
                <a class="nav-link" asp-area="" asp-controller="Config" asp-action="Control">
                    <i class="nav-icon">🔒</i>
                    <span>Access Control</span>
                </a>
            </div>
        </nav>
    </aside>

    <!-- Main area -->
    <div class="main-content">
        <div class="container-fluid">
            <main role="main" class="py-4">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Cabin_Crew
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
