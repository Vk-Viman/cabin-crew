                <div class="mv-field"><label>Crew Category *</label><select id="crewCategory"><option value="">Select category</option><option>Pur</option><option>CS</option><option>FA</option></select></div>
                <div class="mv-field"><label>Crew Position *</label><select id="crewPosition"><option value="">Select position</option><option>L1</option><option>L2</option><option>L4</option><option>R5</option></select></div>
                <div class="mv-field"><label>Is Passive</label><select id="crewPassive"><option>No</option><option>Yes</option></select></div>
