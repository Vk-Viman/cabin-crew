                <div class="mv-header-left">
                    <span class="mv-header-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 4.2 3.8 18.5c-.5.9.1 2 1.2 2h14c1 0 1.7-1.1 1.2-2L12 4.2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
