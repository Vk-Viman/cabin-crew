@{
    ViewData["Title"] = "Manuel Voyage Report";
    var showDemo = string.Equals(Context.Request.Query["showDemo"], "1", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Context.Request.Query["showDemo"], "true", StringComparison.OrdinalIgnoreCase);

    var seededCrewRows = new[]
    {
        new { StaffNo = "CCM-123", Category = "Pur", Citizenship = "LK", Sex = "Female", Birthday = "2001-10-12", Passive = "No", Position = "L1" },
        new { StaffNo = "CCM-789", Category = "CS", Citizenship = "LK", Sex = "Male", Birthday = "2002-06-04", Passive = "Yes", Position = "L4" },
        new { StaffNo = "CCM-234", Category = "FA", Citizenship = "LK", Sex = "Female", Birthday = "2004-01-13", Passive = "Yes", Position = "R5" }
    };

    var seededIncidentRows = new[]
    {
        new { Type = "Medical Emergency", Seat = "12 A", Name = "Johnson", Ticket = "12 A" },
        new { Type = "Equipment Malfunction", Seat = "25 B", Name = "May", Ticket = "25 B" }
    };
}

<div class="mv-page">
    <section class="mv-card mv-main-card">
        <header class="mv-card-header">
            <div class="mv-header-left">
                <span class="mv-header-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7 3.5h7l4 4V20a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 6 20V5A1.5 1.5 0 0 1 7.5 3.5Z" stroke="currentColor" stroke-width="1.6" />
                        <path d="M14 3.5V8h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M9 11h6M9 14h6M9 17h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    </svg>
                </span>
                <h2>Manual Voyage Entry</h2>
            </div>
        </header>

        <div class="mv-card-body">
            <form id="voyageInfoForm" class="mv-form-grid" onsubmit="return false;">
                <div class="mv-field"><label>Flight No *</label><input name="FlightNo" type="text" placeholder="e.g., UL101" /></div>
                <div class="mv-field"><label>Flight Date *</label><input class="mv-date" name="FlightDate" type="text" placeholder="dd/mm/yy" /></div>
                <div class="mv-field"><label>Board Point *</label><select name="BoardPoint"><option value="">Select</option><option>CMB</option><option>DXB</option><option>LHR</option></select></div>
                <div class="mv-field"><label>Air Craft Reg *</label><input name="AircraftReg" type="text" placeholder="Aircraft Registration" /></div>
                <div class="mv-field"><label>Aircraft Type *</label><input name="AircraftType" type="text" placeholder="Aircraft Type" /></div>

                <div class="mv-field"><label>Sector *</label><input name="Sector" type="text" placeholder="Sector" /></div>
                <div class="mv-field"><label>PIC</label><input name="PIC" type="text" placeholder="PIC" /></div>
                <div class="mv-field"><label>STD</label><input name="STD" type="text" placeholder="STD" /></div>
                <div class="mv-field"><label>ATD</label><input name="ATD" type="text" placeholder="ATD" /></div>
                <div class="mv-field"><label>ATA</label><input name="ATA" type="text" placeholder="ATA" /></div>

                <div class="mv-field"><label>CATEROM</label><input name="CATEROM" type="text" placeholder="CATEROM" /></div>
                <div class="mv-field"><label>CCMREADY</label><input name="CCMREADY" type="text" placeholder="CCMREADY" /></div>
                <div class="mv-field"><label>BOARDCOM</label><input name="BOARDCOM" type="text" placeholder="BOARDCOM" /></div>
                <div class="mv-field"><label>LPAXBOARD</label><input name="LPAXBOARD" type="text" placeholder="LPAXBOARD" /></div>
                <div class="mv-field"><label>BC</label><input name="BC" type="text" placeholder="Business Class" /></div>

                <div class="mv-field"><label>EY</label><input name="EY" type="text" placeholder="Economy" /></div>
                <div class="mv-field"><label>AIRCRAFT DEVICE TYPE</label><input name="AIRCRAFT_DEVICE_TYPE" type="text" placeholder="Aircraft Device Type" /></div>
                <div class="mv-field"><label>TOT</label><input name="TOT" type="text" placeholder="Total" /></div>
                <div class="mv-field"><label>INF</label><input name="INF" type="text" placeholder="Infants" /></div>
                <div class="mv-field"><label>BOOKED</label><input name="BOOKED" type="text" placeholder="Booked" /></div>

                <div class="mv-field"><label>REQWVOLUME</label><input name="REQWVOLUME" type="text" placeholder="Required Water Volume" /></div>
                <div class="mv-field"><label>REQWLEVEL</label><input name="REQWLEVEL" type="text" placeholder="Required Water Level" /></div>
                <div class="mv-field"><label>RECWVOLUME</label><input name="RECWVOLUME" type="text" placeholder="Recorded Water Volume" /></div>
                <div class="mv-field"><label>RECWLEVEL</label><input name="RECWLEVEL" type="text" placeholder="Recorded Water Level" /></div>
                <div class="mv-field"><label>WATER REMAIN ON ARRIVAL</label><input name="WATER_REMAIN_ON_ARRIVAL" type="text" placeholder="Water Remaining On Arrival" /></div>

                <div class="mv-field"><label>PICL</label><input name="PICL" type="text" placeholder="PICL" /></div>
                <div class="mv-field"><label>XFD</label><input name="XFD" type="text" placeholder="XFD" /></div>
                <div class="mv-field mv-span-3"><label>GENCOMM</label><input name="GENCOMM" type="text" placeholder="GENCOMM" /></div>
            </form>
        </div>

        <section class="mv-sub-card">
            <header class="mv-sub-header">
                <div class="mv-header-left">
                    <span class="mv-header-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M16 20v-1.1a3.9 3.9 0 0 0-3.9-3.9H8.9A3.9 3.9 0 0 0 5 18.9V20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
