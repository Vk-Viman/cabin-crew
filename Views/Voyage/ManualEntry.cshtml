@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const staffDirectory = [
                { staffNo: "CCM-123", firstName: "Asha", lastName: "Perera", citizenship: "LK", sex: "Female", birthdate: "2001-10-12" },
                { staffNo: "CCM-789", firstName: "Nimal", lastName: "Silva", citizenship: "LK", sex: "Male", birthdate: "2002-06-04" },
                { staffNo: "CCM-234", firstName: "Ravi", lastName: "Fernando", citizenship: "LK", sex: "Female", birthdate: "2004-01-13" }
            ];
            const mockStaffList = document.getElementById("mockStaffList");

            const initialCrewData = @Html.Raw(showDemo ? System.Text.Json.JsonSerializer.Serialize(seededCrewRows) : "[]");
            const initialIncidentData = @Html.Raw(showDemo ? System.Text.Json.JsonSerializer.Serialize(seededIncidentRows) : "[]");

            let crewData = [...initialCrewData];
            let incidentData = [...initialIncidentData];

            let crewSort = { key: "", dir: "asc" };
            let incidentSort = { key: "", dir: "asc" };
            let crewPage = 1;
            let incidentPage = 1;

            const crewStaffNo = document.getElementById("crewStaffNo");
            const crewFirstName = document.getElementById("crewFirstName");
            const crewLastName = document.getElementById("crewLastName");
            const crewCitizenship = document.getElementById("crewCitizenship");
            const crewSex = document.getElementById("crewSex");
            const crewBirthdate = document.getElementById("crewBirthdate");
            const crewCategory = document.getElementById("crewCategory");
            const crewPosition = document.getElementById("crewPosition");
            const crewPassive = document.getElementById("crewPassive");

            const crewAddBtn = document.getElementById("crewAddBtn");
            const crewRemoveLastBtn = document.getElementById("crewRemoveLastBtn");
            const crewViewSection = document.getElementById("crewViewSection");
            const crewTableBody = document.getElementById("crewTableBody");
            const crewSearchInput = document.getElementById("crewSearchInput");
            const crewEntriesSelect = document.getElementById("crewEntriesSelect");
            const crewRecordBadge = document.getElementById("crewRecordBadge");
            const crewPagingInfo = document.getElementById("crewPagingInfo");
            const crewPrevBtn = document.getElementById("crewPrevBtn");
            const crewPageBtn = document.getElementById("crewPageBtn");
            const crewNextBtn = document.getElementById("crewNextBtn");

            const incidentStaffId = document.getElementById("incidentStaffId");
            const incidentType = document.getElementById("incidentType");
            const incidentPaxSeat = document.getElementById("incidentPaxSeat");
            const incidentPaxName = document.getElementById("incidentPaxName");
            const incidentPnrTicket = document.getElementById("incidentPnrTicket");
            const incidentImageInput = document.getElementById("incidentImageInput");
            const incidentDetails = document.getElementById("incidentDetails");

            const incidentAddBtn = document.getElementById("incidentAddBtn");
            const incidentRemoveLastBtn = document.getElementById("incidentRemoveLastBtn");
            const incidentViewSection = document.getElementById("incidentViewSection");
            const incidentTableBody = document.getElementById("incidentTableBody");
            const incidentSearchInput = document.getElementById("incidentSearchInput");
            const incidentEntriesSelect = document.getElementById("incidentEntriesSelect");
            const incidentRecordBadge = document.getElementById("incidentRecordBadge");
            const incidentPagingInfo = document.getElementById("incidentPagingInfo");
            const incidentPrevBtn = document.getElementById("incidentPrevBtn");
            const incidentPageBtn = document.getElementById("incidentPageBtn");
            const incidentNextBtn = document.getElementById("incidentNextBtn");

            const voyageInfoForm = document.getElementById("voyageInfoForm");
            const resetVoyageBtn = document.getElementById("resetVoyageBtn");
            const submitVoyageBtn = document.getElementById("submitVoyageBtn");

            function normalizeDate(value) {
                if (!value) return "";
                const dt = new Date(value);
                if (Number.isNaN(dt.getTime())) return value;
                const y = dt.getFullYear();
                const m = String(dt.getMonth() + 1).padStart(2, "0");
                const d = String(dt.getDate()).padStart(2, "0");
                return `${y}-${m}-${d}`;
            }

            function applySort(rows, sort) {
                if (!sort.key) return rows;
                return [...rows].sort((a, b) => {
                    const av = String(a[sort.key] ?? "").toLowerCase();
                    const bv = String(b[sort.key] ?? "").toLowerCase();
                    if (av < bv) return sort.dir === "asc" ? -1 : 1;
                    if (av > bv) return sort.dir === "asc" ? 1 : -1;
                    return 0;
                });
            }

            function buildStaffOptions() {
                if (!mockStaffList) return;
                const options = staffDirectory
                    .map((s) => `<option value="${s.staffNo}">${s.firstName} ${s.lastName}</option>`)
                    .join("");
                mockStaffList.innerHTML = options;
            }

            function findStaff(query) {
                const q = (query || "").trim().toLowerCase();
                if (!q) return null;

                const exact = staffDirectory.find((s) =>
                    s.staffNo.toLowerCase() === q ||
                    `${s.firstName} ${s.lastName}`.toLowerCase() === q
                );
                if (exact) return exact;

                return staffDirectory.find((s) =>
                    s.staffNo.toLowerCase().includes(q) ||
                    `${s.firstName} ${s.lastName}`.toLowerCase().includes(q)
                ) || null;
            }

            function autofillCrewFromStaff(staff) {
                if (!staff) return;
                crewStaffNo.value = staff.staffNo;
                crewFirstName.value = staff.firstName;
                crewLastName.value = staff.lastName;
                crewCitizenship.value = staff.citizenship;
                crewSex.value = staff.sex;
                crewBirthdate.value = staff.birthdate;
            }

            function renderCrewTable() {
                const searchTerm = (crewSearchInput.value || "").trim().toLowerCase();
                const limit = parseInt(crewEntriesSelect.value || "10", 10);

                let rows = crewData.filter((r) => {
                    if (!searchTerm) return true;
                    return Object.values(r).some((v) => String(v).toLowerCase().includes(searchTerm));
                });
                rows = applySort(rows, crewSort);

                const totalPages = Math.max(1, Math.ceil(rows.length / limit));
                if (crewPage > totalPages) {
                    crewPage = totalPages;
                }
                const startIndex = (crewPage - 1) * limit;
                const visibleRows = rows.slice(startIndex, startIndex + limit);
                crewViewSection.classList.toggle("d-none", crewData.length === 0);
                crewRecordBadge.textContent = `${crewData.length} records`;
                const startDisplay = rows.length ? startIndex + 1 : 0;
                const endDisplay = startIndex + visibleRows.length;
                crewPagingInfo.textContent = `Showing ${startDisplay} to ${endDisplay} of ${rows.length} entries`;
                crewPageBtn.textContent = String(crewPage);
                crewPrevBtn.disabled = crewPage <= 1;
                crewNextBtn.disabled = crewPage >= totalPages;

                crewTableBody.innerHTML = visibleRows.length
                    ? visibleRows.map((r) => `
                        <tr>
                            <td>${r.StaffNo}</td>
                            <td><span class="mv-chip">${r.Category}</span></td>
                            <td>${r.Citizenship}</td>
                            <td>${r.Sex}</td>
                            <td>${r.Birthday}</td>
                            <td><span class="mv-chip mv-chip-passive">${r.Passive}</span></td>
                            <td>${r.Position}</td>
                        </tr>
                    `).join("")
                    : `<tr><td colspan="7" class="mv-empty-row">No matching crew records</td></tr>`;
            }

            function renderIncidentTable() {
                const searchTerm = (incidentSearchInput.value || "").trim().toLowerCase();
                const limit = parseInt(incidentEntriesSelect.value || "10", 10);

                let rows = incidentData.filter((r) => {
                    if (!searchTerm) return true;
                    return Object.values(r).some((v) => String(v).toLowerCase().includes(searchTerm));
                });
                rows = applySort(rows, incidentSort);

                const totalPages = Math.max(1, Math.ceil(rows.length / limit));
                if (incidentPage > totalPages) {
                    incidentPage = totalPages;
                }
                const startIndex = (incidentPage - 1) * limit;
                const visibleRows = rows.slice(startIndex, startIndex + limit);
                incidentViewSection.classList.toggle("d-none", incidentData.length === 0);
                incidentRecordBadge.textContent = `${incidentData.length} records`;
                const startDisplay = rows.length ? startIndex + 1 : 0;
                const endDisplay = startIndex + visibleRows.length;
                incidentPagingInfo.textContent = `Showing ${startDisplay} to ${endDisplay} of ${rows.length} entries`;
                incidentPageBtn.textContent = String(incidentPage);
                incidentPrevBtn.disabled = incidentPage <= 1;
                incidentNextBtn.disabled = incidentPage >= totalPages;

                incidentTableBody.innerHTML = visibleRows.length
                    ? visibleRows.map((r) => `
                        <tr>
                            <td><span class="mv-chip mv-chip-incident">${r.Type}</span></td>
                            <td>${r.Seat}</td>
                            <td>${r.Name}</td>
                            <td>${r.Ticket}</td>
                        </tr>
                    `).join("")
                    : `<tr><td colspan="4" class="mv-empty-row">No matching incident records</td></tr>`;
            }

            function handleCrewStaffLookup() {
                const found = findStaff(crewStaffNo.value);
                if (!found) return;
                autofillCrewFromStaff(found);
            }

            crewStaffNo.addEventListener("input", handleCrewStaffLookup);
            crewStaffNo.addEventListener("change", handleCrewStaffLookup);
            crewStaffNo.addEventListener("blur", handleCrewStaffLookup);

            function handleIncidentStaffLookup() {
                const found = findStaff(incidentStaffId.value);
                if (!found) return;
                incidentStaffId.value = found.staffNo;
                if (!incidentPaxName.value.trim()) {
                    incidentPaxName.value = `${found.firstName} ${found.lastName}`;
                }
            }

            incidentStaffId.addEventListener("input", handleIncidentStaffLookup);
            incidentStaffId.addEventListener("change", handleIncidentStaffLookup);
            incidentStaffId.addEventListener("blur", handleIncidentStaffLookup);

            crewAddBtn.addEventListener("click", function () {
                const payload = {
                    StaffNo: crewStaffNo.value.trim(),
                    Category: crewCategory.value.trim(),
                    Citizenship: crewCitizenship.value.trim(),
                    Sex: crewSex.value.trim(),
                    Birthday: normalizeDate(crewBirthdate.value.trim()),
                    Passive: crewPassive.value.trim() || "No",
                    Position: crewPosition.value.trim()
                };

                if (!payload.StaffNo || !payload.Category || !payload.Position) {
                    alert("Please fill Staff No, Crew Category, and Crew Position.");
                    return;
                }

                crewData.push(payload);
                crewPage = Math.max(1, Math.ceil(crewData.length / parseInt(crewEntriesSelect.value || "10", 10)));
                renderCrewTable();
            });

            crewRemoveLastBtn.addEventListener("click", function () {
                if (!crewData.length) return;
                crewData.pop();
                renderCrewTable();
            });

            incidentAddBtn.addEventListener("click", function () {
                const payload = {
                    Type: incidentType.value.trim(),
                    Seat: incidentPaxSeat.value.trim(),
                    Name: incidentPaxName.value.trim() || incidentStaffId.value.trim() || "Unknown",
                    Ticket: incidentPnrTicket.value.trim() || "N/A",
                    Details: incidentDetails.value.trim(),
                    Image: incidentImageInput.files && incidentImageInput.files.length ? incidentImageInput.files[0].name : ""
                };

                if (!payload.Type || !payload.Seat) {
                    alert("Please fill Incident Type and PAX Seat.");
                    return;
                }

                incidentData.push(payload);
                incidentPage = Math.max(1, Math.ceil(incidentData.length / parseInt(incidentEntriesSelect.value || "10", 10)));
                renderIncidentTable();
            });

            incidentRemoveLastBtn.addEventListener("click", function () {
                if (!incidentData.length) return;
                incidentData.pop();
                renderIncidentTable();
            });

            crewEntriesSelect.addEventListener("change", function () {
                crewPage = 1;
                renderCrewTable();
            });
            incidentEntriesSelect.addEventListener("change", function () {
                incidentPage = 1;
                renderIncidentTable();
            });

            crewSearchInput.addEventListener("input", function () {
                crewPage = 1;
                renderCrewTable();
            });

            incidentSearchInput.addEventListener("input", function () {
                incidentPage = 1;
                renderIncidentTable();
            });

            crewPrevBtn.addEventListener("click", function () {
                if (crewPage <= 1) return;
                crewPage -= 1;
                renderCrewTable();
            });

            crewNextBtn.addEventListener("click", function () {
                const limit = parseInt(crewEntriesSelect.value || "10", 10);
                const searchTerm = (crewSearchInput.value || "").trim().toLowerCase();
                const filtered = applySort(
                    crewData.filter((r) => !searchTerm || Object.values(r).some((v) => String(v).toLowerCase().includes(searchTerm))),
                    crewSort
                );
                const totalPages = Math.max(1, Math.ceil(filtered.length / limit));
                if (crewPage >= totalPages) return;
                crewPage += 1;
                renderCrewTable();
            });

            incidentPrevBtn.addEventListener("click", function () {
                if (incidentPage <= 1) return;
                incidentPage -= 1;
                renderIncidentTable();
            });

            incidentNextBtn.addEventListener("click", function () {
                const limit = parseInt(incidentEntriesSelect.value || "10", 10);
                const searchTerm = (incidentSearchInput.value || "").trim().toLowerCase();
                const filtered = applySort(
                    incidentData.filter((r) => !searchTerm || Object.values(r).some((v) => String(v).toLowerCase().includes(searchTerm))),
                    incidentSort
                );
                const totalPages = Math.max(1, Math.ceil(filtered.length / limit));
                if (incidentPage >= totalPages) return;
                incidentPage += 1;
                renderIncidentTable();
            });

            document.querySelectorAll(".mv-sort").forEach(function (th) {
                th.addEventListener("click", function () {
                    const table = th.dataset.table;
                    const key = th.dataset.key;
                    const sortRef = table === "crew" ? crewSort : incidentSort;

                    if (sortRef.key === key) {
                        sortRef.dir = sortRef.dir === "asc" ? "desc" : "asc";
                    } else {
                        sortRef.key = key;
                        sortRef.dir = "asc";
                    }

                    if (table === "crew") {
                        renderCrewTable();
                    } else {
                        renderIncidentTable();
                    }
                });
            });

            resetVoyageBtn.addEventListener("click", function () {
                voyageInfoForm.reset();
                crewFirstName.value = "";
                crewLastName.value = "";
                crewCitizenship.value = "";
                crewSex.value = "";
                crewBirthdate.value = "";
                incidentType.value = "";
                incidentPaxSeat.value = "";
                incidentPaxName.value = "";
                incidentPnrTicket.value = "";
                incidentStaffId.value = "";
                incidentDetails.value = "";
                if (incidentImageInput) {
                    incidentImageInput.value = "";
                }
            });

            submitVoyageBtn.addEventListener("click", function () {
                const voyageData = Object.fromEntries(new FormData(voyageInfoForm).entries());
                const payload = {
                    voyage: voyageData,
                    crew: crewData,
                    incidents: incidentData
                };
                console.log("Manual Voyage Submit Payload", payload);
                alert(`Voyage report prepared with ${crewData.length} crew and ${incidentData.length} incidents.`);
            });

            document.querySelectorAll(".mv-date").forEach(function (el) {
                el.addEventListener("focus", function () { el.type = "date"; });
                el.addEventListener("blur", function () { if (!el.value) { el.type = "text"; } });
            });

            buildStaffOptions();
            renderCrewTable();
            renderIncidentTable();
        });
    </script>
}

@section Styles {
    <style>
        .mv-page {
            --mv-bg: #dddddd;
            --mv-card: #ffffff;
            --mv-ink: #1a1a1a;
            --mv-header: #272727;
            --mv-input: #f3f3f5;
            --mv-input-text: #717182;
            --mv-input-label: #364153;
            --mv-table-head: rgba(131, 157, 187, 0.7);
            --mv-border: rgba(0, 0, 0, 0.1);
            --mv-add: #1c9b00;
            --mv-add-hover: #178000;
            --mv-remove: #dc001c;
            --mv-remove-hover: #bd0018;
            --mv-reset: #e4a127;
            --mv-reset-hover: #c98d21;
            --mv-submit: #0f1e7d;
            --mv-submit-hover: #0c1865;
        }

        .mv-page {
            padding: 0;
            background: var(--mv-bg);
            min-height: calc(100vh - 92px);
            font-family: Arial, sans-serif;
        }

        .mv-card {
            background: var(--mv-card);
            border-radius: 14px;
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1), 0 4px 6px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .mv-main-card {
            margin: 0;
        }

        .mv-card-header,
        .mv-sub-header {
            background: var(--mv-header);
            color: #ffffff;
            min-height: 65px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 24px;
        }

        .mv-sub-header-light {
            background: #272727;
        }

        .mv-header-left {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .mv-header-icon {
            width: 25px;
            height: 25px;
            flex: 0 0 25px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
        }

        .mv-header-icon svg {
            width: 100%;
            height: 100%;
        }

        .mv-card-header h2,
        .mv-sub-header h3 {
            margin: 0;
            font-size: 20px;
            font-weight: 400;
            color: #ffffff;
            line-height: 1;
        }

        .mv-card-body,
        .mv-sub-body {
            padding: 24px;
        }

        .mv-form-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 30px 65px;
        }

        .mv-crew-add-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 30px 65px;
            align-items: end;
        }

        .mv-inc-add-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 30px 65px;
            align-items: end;
        }

        .mv-span-2 {
            grid-column: span 2;
        }

        .mv-span-3 {
            grid-column: span 3;
        }

        .mv-field {
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: 0;
        }

        .mv-field label {
            font-size: 16px;
            font-weight: 700;
            color: var(--mv-input-label);
            line-height: 16px;
        }

        .mv-field input,
        .mv-field select,
        .mv-field textarea {
            height: 36px;
            width: 100%;
            border: 1px solid transparent;
            border-radius: 8px;
            background: var(--mv-input);
            color: var(--mv-input-text);
            font-size: 14px;
            padding: 8px 12px;
            outline: none;
            box-shadow: none;
        }

        .mv-field textarea {
            height: 64px;
            resize: none;
        }

        .mv-field input[type="file"] {
            padding: 6px 10px;
        }

        .mv-field input:focus,
        .mv-field select:focus,
        .mv-field textarea:focus {
            border-color: #0f1e7d;
        }

        .mv-sub-card {
            border-top: 1px solid rgba(0, 0, 0, 0.08);
            margin-top: 12px;
            padding-bottom: 24px;
        }

        .mv-table-card {
            margin-top: 28px;
            border: 1px solid var(--mv-border);
            border-radius: 10px;
            overflow: hidden;
            background: var(--mv-card);
        }

        .mv-table-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            padding: 14px 16px;
        }

        .mv-toolbar-left {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: var(--mv-ink);
        }

        .mv-toolbar-left select {
            width: 64px;
            height: 28px;
            border-radius: 8px;
            border: 1px solid #d0d5dd;
            padding: 0 10px;
            background: #ffffff;
            font-size: 12px;
        }

        .mv-badge {
            margin-left: 10px;
            padding: 4px 10px;
            border-radius: 999px;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            color: #364153;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .mv-toolbar-search input {
            width: 250px;
            height: 32px;
            border-radius: 8px;
            border: 1px solid #d0d5dd;
            padding: 6px 10px 6px 32px;
            font-size: 12px;
            color: #6b7280;
            background: #ffffff;
        }

        .mv-toolbar-search {
            position: relative;
        }

        .mv-search-icon {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 14px;
            height: 14px;
            color: #9ca3af;
            pointer-events: none;
            display: inline-flex;
        }

        .mv-search-icon svg {
            width: 100%;
            height: 100%;
        }

        .mv-table-wrap {
            overflow-x: auto;
            border-top: 1px solid var(--mv-border);
            border-bottom: 1px solid var(--mv-border);
        }

        .mv-table {
            width: 100%;
            min-width: 1200px;
            border-collapse: collapse;
        }

        .mv-inc-table {
            min-width: 900px;
        }

        .mv-table thead {
            background: var(--mv-table-head);
        }

        .mv-table th,
        .mv-table td {
            text-align: left;
            padding: 0 12px;
            height: 44px;
            border-top: 1px solid var(--mv-border);
            color: var(--mv-ink);
            font-size: 12px;
            white-space: nowrap;
            vertical-align: middle;
        }

        .mv-table td {
            height: 46px;
        }

        .mv-table th {
            border-top: 0;
            font-weight: 700;
            cursor: pointer;
            user-select: none;
            letter-spacing: 0.1px;
        }

        .mv-table th.mv-sort::after {
            content: "\2195";
            margin-left: 8px;
            color: #6a7890;
            font-size: 10px;
        }

        .mv-table tbody tr:nth-child(even) {
            background: rgba(21, 93, 252, 0.1);
        }

        .mv-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 44px;
            height: 18px;
            border-radius: 999px;
            padding: 0 8px;
            background: #ffffff;
            border: 1px solid #d1d5dc;
            color: #1a1a1a;
            font-size: 10px;
            font-weight: 700;
