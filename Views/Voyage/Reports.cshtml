                    { count: report.crewInformation.length, searchPlaceholder: "Search crew...", tableKey: "crew" }
                );

                const regulatoryCards = report.regulatory.map((item) => {
                    const status = regulatoryStatus(item);
                    return `
                        <div class="vr-reg-item ${status}">
                            <span class="vr-reg-label">${item.label}</span>
