                    "/images/icons/section-header.svg",
                    ["CAT", "POS", "Name", "StaffID", "Sign"],
                    snyRows,
                    "No SNY crew recorded.",
                    { count: report.snyCrew.length, searchPlaceholder: "Search SNY crew...", tableKey: "sny" }
                );

                const passengerRows = report.passengers.map((item) => `
                    <tr>
                        <td>${item.passengerName}</td>
                        <td>${item.seatNumber}</td>
