                const passengers = dataTableCard(
                    "Passengers",
                    "/images/icons/section-header.svg",
                    ["Passenger Name", "Seat Number", "Ticket Number", "PNR Number"],
                    passengerRows,
                    "No passenger records available.",
                    {
                        count: report.passengers.length,
                        titleSuffix: "",
                        iconMarkup: sectionHeaderIcon("person"),
                        searchPlaceholder: "Search passengers...",
