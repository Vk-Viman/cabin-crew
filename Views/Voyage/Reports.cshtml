                                    </tr>
                                </thead>
                                <tbody class="vr-js-tbody" data-colspan="4" data-empty-message="No safety confirmation records available.">${safetyRows.length ? safetyRows.join("") : `<tr><td colspan="4" class="vr-empty-row">No safety confirmation records available.</td></tr>`}</tbody>
                            </table>
                        </div>
                        <div class="vr-safety-footer">
                            <span class="vr-js-info">Showing 1 to ${report.safetyConfirmation.length} of ${report.safetyConfirmation.length} entries</span>
                            <div class="vr-safety-pager">
                                <button type="button" class="vr-js-prev" disabled>Previous</button>
                                <button type="button" class="active vr-js-page">1</button>
                                <button type="button" class="vr-js-next" disabled>Next</button>
                            </div>
                        </div>
                        </div>`,
                    "vr-safety-card",
                    "data-table-key=\"safety\""
                );

                const delayReport = sectionCard("Delay Comments", `<div class="vr-alert-box">${report.delayReport}</div>`);
                const generalComments = sectionCard("General Comments", `<div class="vr-info-box">${report.generalComments}</div>`);

                const snyRows = report.snyCrew.map((item) => `
                    <tr>
                        <td>${catBadge(item.cat)}</td>
                        <td>${item.pos}</td>
                        <td>${item.name}</td>
                        <td>${item.staffId}</td>
                        <td>${signBadge(item.sign)}</td>
                    </tr>
                `);
                const snyCrew = dataTableCard(
