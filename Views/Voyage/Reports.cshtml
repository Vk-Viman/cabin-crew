                        <div class="vr-section-body vr-incident-wrap">
                            <div class="vr-incident-toolbar">
                                <div class="vr-safety-toolbar-left vr-incident-toolbar-left">
                                    <span>Show</span>
                                    <select class="vr-toolbar-select vr-js-entries" aria-label="Entries per page">
                                        <option value="10" selected>10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                    </select>
                                    <span>entries</span>
                                    <span class="vr-badge">${report.incidents.length} records</span>
                                </div>
                                <div class="vr-incident-toolbar-search">
                                    <span class="vr-toolbar-search-icon" aria-hidden="true">
                                        <img src="/images/icons/search-muted.svg" alt="" />
                                    </span>
                                    <input class="vr-js-search" type="text" placeholder="Search incidents..." />
                                </div>
                            </div>
                            <div class="vr-table-wrap">
                                <table class="vr-table vr-detail-table vr-incident-table">
                                    <thead>
                                        <tr>
                                            <th>PNR Ticket</th>
                                            <th>Main Category</th>
                                            <th>Incident Description</th>
                                            <th>More Details</th>
                                            <th>PAX Name</th>
                                            <th>PAX Seat</th>
                                            <th>Reported by</th>
                                            <th>Incident ID</th>
                                            <th>Assigned Inspector/s</th>
                                            <th>Status</th>
                                            <th>Assigned By</th>
                                            <th>Image</th>
                                        </tr>
                                    </thead>
                                    <tbody class="vr-js-tbody" data-colspan="12" data-empty-message="No incidents recorded for this voyage.">${incidentRows.length ? incidentRows.join("") : `<tr><td colspan="12" class="vr-empty-row">No incidents recorded for this voyage.</td></tr>`}</tbody>
                                </table>
                            </div>
                            <div class="vr-incident-footer">
                                <span class="vr-js-info">Showing 1 to ${report.incidents.length} of ${report.incidents.length} entries</span>
                                <div class="vr-incident-pager">
                                    <button type="button" class="vr-js-prev" disabled>Previous</button>
                                    <button type="button" class="active vr-js-page">1</button>
                                    <button type="button" class="vr-js-next" disabled>Next</button>
                                </div>
                            </div>
                        </div>
                    </section>`;
            }

            function renderTabStrip(report) {
                if (!el.tabStrip || !report) return;

                const tabs = [
                    { key: "general", label: "General" },
                    { key: "crew", label: "Crew Info" },
                    { key: "regulatory", label: "Regulatory" },
                    { key: "safety", label: "Safety" },
                    { key: "incidents", label: "Incidents" },
                    { key: "passengers", label: "Passengers" },
                    { key: "services", label: "Services" }
                ];

                el.tabStrip.innerHTML = tabs.map((tab) => `
                    <button type="button" class="vr-tab-btn ${state.selectedTab === tab.key ? "active" : ""}" data-tab-key="${tab.key}" aria-pressed="${state.selectedTab === tab.key ? "true" : "false"}">${tab.label}</button>
                `).join("");

                el.tabStrip.querySelectorAll(".vr-tab-btn").forEach((button) => {
                    button.addEventListener("click", function () {
                        state.selectedTab = this.getAttribute("data-tab-key") || "general";
                        renderDetail();
                    });
                });
            }

            function kvGrid(items) {
                return `<div class="vr-kv-grid">${items.map((item) => `
                    <div class="vr-kv-item">
                        <span>${item.label}</span>
                        <strong>${item.value}</strong>
                    </div>
                `).join("")}</div>`;
            }

            function simpleTable(headers, rows, emptyMessage, colspan) {
                const body = rows.length
                    ? rows.join("")
                    : `<tr><td colspan="${colspan}" class="vr-empty-row">${emptyMessage}</td></tr>`;
                return `<div class="vr-table-wrap"><table class="vr-table vr-detail-table"><thead><tr>${headers.map((header) => `<th>${header}</th>`).join("")}</tr></thead><tbody>${body}</tbody></table></div>`;
            }

            function wireDetailTableInteractions(report) {
                if (!el.detailSections) return;

                el.detailSections.querySelectorAll("[data-table-key]").forEach((card) => {
                    const tableKey = card.getAttribute("data-table-key") || "";
                    const tbody = card.querySelector(".vr-js-tbody");
                    if (!tbody) return;

                    const searchInput = card.querySelector(".vr-js-search");
                    const entriesSelect = card.querySelector(".vr-js-entries");
                    const badge = card.querySelector(".vr-badge");
                    const info = card.querySelector(".vr-js-info");
                    const prevBtn = card.querySelector(".vr-js-prev");
                    const pageBtn = card.querySelector(".vr-js-page");
                    const nextBtn = card.querySelector(".vr-js-next");
                    const colspan = parseInt(tbody.getAttribute("data-colspan") || "1", 10);
                    const emptyMessage = tbody.getAttribute("data-empty-message") || "No records found.";

                    const sourceRows = Array.from(tbody.querySelectorAll("tr"))
                        .filter((row) => !row.querySelector(".vr-empty-row"))
                        .map((row) => ({
                            html: row.outerHTML,
                            text: (row.textContent || "").toLowerCase()
                        }));

                    let page = 1;
                    let pageSize = parseInt(entriesSelect ? entriesSelect.value : "10", 10);
                    let search = "";

                    function renderTableState() {
                        const query = search.trim().toLowerCase();
                        const filtered = query
                            ? sourceRows.filter((row) => row.text.includes(query))
                            : sourceRows;

                        const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
                        if (page > totalPages) page = totalPages;
                        const start = (page - 1) * pageSize;
                        const visible = filtered.slice(start, start + pageSize);

                        tbody.innerHTML = visible.length
                            ? visible.map((row) => row.html).join("")
                            : `<tr><td colspan="${colspan}" class="vr-empty-row">${emptyMessage}</td></tr>`;

                        if (badge) {
                            badge.textContent = `${filtered.length} records`;
                        }

                        if (info) {
                            const from = filtered.length ? start + 1 : 0;
                            const to = start + visible.length;
                            info.textContent = `Showing ${from} to ${to} of ${filtered.length} entries`;
                        }

                        if (pageBtn) pageBtn.textContent = String(page);
                        if (prevBtn) prevBtn.disabled = page <= 1;
                        if (nextBtn) nextBtn.disabled = page >= totalPages;

                        if (tableKey === "incidents") {
                            tbody.querySelectorAll(".vr-incident-gallery-btn").forEach((button) => {
                                button.addEventListener("click", function () {
                                    const index = parseInt(this.getAttribute("data-incident-index") || "0", 10);
                                    openGallery(report.incidents[index]);
                                });
                            });
                        }
                    }

                    if (searchInput) {
                        searchInput.addEventListener("input", function () {
                            search = this.value;
                            page = 1;
                            renderTableState();
                        });
                    }

                    if (entriesSelect) {
                        entriesSelect.addEventListener("change", function () {
                            pageSize = parseInt(this.value, 10);
                            page = 1;
                            renderTableState();
                        });
                    }

                    if (prevBtn) {
                        prevBtn.addEventListener("click", function () {
                            if (page <= 1) return;
                            page -= 1;
                            renderTableState();
                        });
                    }

                    if (nextBtn) {
                        nextBtn.addEventListener("click", function () {
                            const query = search.trim().toLowerCase();
                            const filtered = query
                                ? sourceRows.filter((row) => row.text.includes(query))
                                : sourceRows;
                            const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
                            if (page >= totalPages) return;
                            page += 1;
                            renderTableState();
                        });
                    }

                    renderTableState();
                });
            }

            function renderDetailSections(report) {
                if (!el.detailSections || !report) return;

                const generalInfo = sectionCard(
                    "General Information",
                    kvGrid([
                        { label: "Scheduled Time of Departure", value: report.generalInformation.std },
