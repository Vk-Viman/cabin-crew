                    }
                );

                const flySmilesRows = report.flySmiles.map((item) => `
                    <tr>
                        <td>${catBadge(item.cabin)}</td>
                        <td>${item.flySmilesNo}</td>
                        <td>${item.memberName}</td>
                        <td>${item.tier}</td>
                        <td>${item.seatNo}</td>
                    </tr>
                `);
                const flySmiles = dataTableCard(
                    "FlySmiles PAX",
                    "/images/icons/section-header.svg",
                    ["Cabin", "FlySmiles No", "Member Name", "Tier", "Seat No"],
                    flySmilesRows,
                    "No FlySmiles passengers recorded.",
                    {
                        count: report.flySmiles.length,
                        titleSuffix: "",
                        iconMarkup: sectionHeaderIcon("person"),
                        searchPlaceholder: "Search FlySmiles members...",
                        showFooter: true,
                        footerLabel: `Showing 1 to ${report.flySmiles.length} of ${report.flySmiles.length} entries`,
                        cardClass: "vr-passenger-card",
                        headerClass: "vr-passenger-header",
                        bodyClass: "vr-passenger-body",
                        tableClass: "vr-flysmiles-table",
                        tableKey: "flysmiles"
                    }
                );

                const specialNeedsRows = report.specialNeeds.map((item) => `
                    <tr>
                        <td>${catBadge(item.cabin)}</td>
                        <td>${item.paxName}</td>
                        <td>${item.serviceCode}</td>
                        <td>${item.description}</td>
                        <td>${item.seatNo}</td>
                    </tr>
                `);
                const specialNeeds = dataTableCard(
                    "Special Needs PAX",
                    "/images/icons/section-header.svg",
                    ["Cabin", "PAX Name", "Service Code", "Description", "Seat No"],
                    specialNeedsRows,
                    "No special needs passengers recorded.",
                    {
                        count: report.specialNeeds.length,
                        titleSuffix: "",
                        iconMarkup: sectionHeaderIcon("warning"),
                        searchPlaceholder: "Search special needs passengers...",
                        showFooter: true,
                        footerLabel: `Showing 1 to ${report.specialNeeds.length} of ${report.specialNeeds.length} entries`,
                        cardClass: "vr-passenger-card",
                        headerClass: "vr-passenger-header",
                        bodyClass: "vr-passenger-body",
                        tableClass: "vr-special-needs-table",
                        tableKey: "special-needs"
                    }
                );

                const neighborRows = report.neighborFreeSeat.map((item) => `
                    <tr>
                        <td>${catBadge(item.cabin)}</td>
                        <td>${item.paxName}</td>
                        <td>${item.serviceCode}</td>
                        <td>${item.checkInSeatNo}</td>
                        <td>${item.neighbourFreeSeat}</td>
                        <td>${item.details}</td>
                    </tr>
                `);
                const neighborFreeSeat = dataTableCard(
                    "Neighbor Free Seat",
                    "/images/icons/section-header.svg",
                    ["Cabin", "PAX Name", "Service Code", "Check-In SeatNo", "Neighbour Free Seat", "Details"],
                    neighborRows,
                    "No neighbour free seat records available.",
                    {
                        count: report.neighborFreeSeat.length,
                        titleSuffix: "",
                        iconMarkup: sectionHeaderIcon("person"),
                        searchPlaceholder: "Search neighbor free seats...",
                        showFooter: true,
                        footerLabel: `Showing 1 to ${report.neighborFreeSeat.length} of ${report.neighborFreeSeat.length} entries`,
                        cardClass: "vr-passenger-card",
                        headerClass: "vr-passenger-header",
                        bodyClass: "vr-passenger-body",
                        tableClass: "vr-neighbor-seat-table",
                        tableKey: "neighbor-free-seat"
                    }
                );

                const water = sectionCard("Water", kvGrid([{ label: "Water Remaining On Arrival", value: report.water }]));

                const mealsRows = report.meals.map((item) => `
                    <tr>
                        <td>${item.mealType}</td>
                        <td>${item.measurementUnit}</td>
                        <td>${item.bcCateredMeals}</td>
                        <td>${item.bcRemainingMeals}</td>
                        <td>${item.eyCateredMeals}</td>
                        <td>${item.eyRemainingMeals}</td>
                    </tr>
                `);
                const meals = dataTableCard(
                    "Meal Consumption",
                    "/images/icons/section-header.svg",
                    ["Meal Type", "Measurement Unit", "BC Catered Meals", "BC Remaining Meals", "EY Catered Meals", "EY Remaining Meals"],
                    mealsRows,
                    "No meal consumption records available.",
                    {
                        count: report.meals.length,
                        titleSuffix: "",
                        iconMarkup: sectionHeaderIcon("meal"),
                        searchPlaceholder: "Search meals...",
                        showFooter: true,
                        footerLabel: `Showing 1 to ${report.meals.length} of ${report.meals.length} entries`,
                        cardClass: "vr-services-card",
                        headerClass: "vr-services-header",
                        bodyClass: "vr-services-body",
                        tableClass: "vr-services-table",
                        tableKey: "meals"
                    }
                );

                let content = "";

                if (state.selectedTab === "general") {
                    content = [generalInfo, delayReport, generalComments].join("");
                } else if (state.selectedTab === "crew") {
                    content = [crewInfo, snyCrew].join("");
                } else if (state.selectedTab === "regulatory") {
                    content = regulatory;
                } else if (state.selectedTab === "safety") {
                    content = safety;
                } else if (state.selectedTab === "incidents") {
                    content = report.incidents.length ? incidentCard(report) : emptyIncidentCard();
                } else if (state.selectedTab === "passengers") {
                    content = [passengers, flySmiles, specialNeeds, neighborFreeSeat].join("");
                } else if (state.selectedTab === "services") {
                    const waterPanel = sectionCard(
                        `<span class="vr-services-title"><span class="vr-services-icon" aria-hidden="true">${sectionHeaderIcon("water")}</span>Water Consumption</span>`,
                        `<div class="vr-water-panel"><div class="vr-water-label">WATER REMAINING ON ARRIVAL</div><div class="vr-water-value">${report.water}</div></div>`,
                        "vr-services-water-card"
                    );
                    content = [waterPanel, meals].join("");
                }

                el.detailSections.innerHTML = content;
                wireDetailTableInteractions(report);
            }

            function renderSummary() {
                const rows = summaryRows();
                const pageSize = state.summaryEntries;
                const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
                if (state.summaryPage > totalPages) state.summaryPage = totalPages;
                const start = (state.summaryPage - 1) * pageSize;
                const visible = rows.slice(start, start + pageSize);

                if (el.recordBadge) el.recordBadge.textContent = `${rows.length} records`;
                if (el.pageBtn) el.pageBtn.textContent = String(state.summaryPage);
                if (el.prevBtn) el.prevBtn.disabled = state.summaryPage <= 1;
                if (el.nextBtn) el.nextBtn.disabled = state.summaryPage >= totalPages;
                if (el.pagingInfo) {
                    const from = rows.length ? start + 1 : 0;
                    const to = start + visible.length;
                    el.pagingInfo.textContent = `Showing ${from} to ${to} of ${rows.length} entries`;
                }

                if (!el.summaryBody) return;
                el.summaryBody.innerHTML = visible.length
                    ? visible.map((row) => `
                        <tr class="vr-click-row" data-key="${row.flightNo}::${row.flightDate}">
                            <td>${dateLabel(row.flightDate)}</td>
                            <td>${row.flightNo}</td>
                            <td>${row.boardPoint}</td>
                            <td>${row.offPoint}</td>
                        </tr>
                    `).join("")
                    : `<tr><td colspan="4" class="vr-empty-row">No matching voyage reports found</td></tr>`;

                document.querySelectorAll(".vr-click-row").forEach((row) => {
                    row.addEventListener("click", function () {
                        state.selectedId = this.getAttribute("data-key") || "";
                        state.selectedTab = "general";
                        renderView();
                    });
                });
            }

            function renderDetail() {
                const report = getSelectedReport();
                if (!report) return;
                if (el.bannerFlight) el.bannerFlight.textContent = `Flight ${report.flightNo}`;
                if (el.bannerRoute) el.bannerRoute.textContent = `${report.boardPoint} → ${report.offPoint}`;
                if (el.bannerDate) el.bannerDate.textContent = dateLabel(report.flightDate);
                if (el.bannerPax) el.bannerPax.textContent = String(report.generalInformation.total);
                if (el.bannerCrew) el.bannerCrew.textContent = String(report.crewInformation.length);
                if (el.bannerIncidents) el.bannerIncidents.textContent = String(report.incidents.length);
                renderTabStrip(report);
                renderDetailSections(report);
            }

            function openGallery(incident) {
                if (!incident || !el.galleryModal || !el.galleryBody || !el.galleryTitle) return;
                el.galleryTitle.textContent = `${incident.incidentId} Images`;
                el.galleryBody.innerHTML = `
                    <div class="vr-gallery-grid">
                        ${incident.images.map((image) => `
                            <figure class="vr-gallery-item">
                                <img src="${image.src}" alt="${image.caption}" />
                                <figcaption>${image.caption}</figcaption>
                            </figure>
                        `).join("")}
                    </div>
                `;
                setHidden(el.galleryModal, false);
            }

            function showState(which) {
                setHidden(el.emptyState, true);
                setHidden(el.summaryState, true);
                setHidden(el.detailState, true);
                setHidden(el.searchCard, false);

                if (which === "empty") setHidden(el.emptyState, false);
                if (which === "summary") setHidden(el.summaryState, false);
                if (which === "detail") {
                    setHidden(el.searchCard, true);
                    setHidden(el.detailState, false);
                }
            }

            function renderView() {
                if (state.selectedId) {
                    const selectedReport = getSelectedReport();
                    if (!selectedReport) {
                        state.selectedId = "";
                        state.selectedTab = "general";
                    } else {
                        showState("detail");
                        renderDetail();
                        return;
                    }
                }

                const rows = summaryRows();
                if (!state.searched) {
                    setEmptyStateText(
                        "Ready to Search",
                        "Use the filters above to search voyage reports by flight.<br />Enter flight details to get started."
                    );
                    showState("empty");
                    return;
                }

                if (!rows.length) {
                    showState("empty");
                    setEmptyStateText(
                        "No Results Found",
                        isGroundUser
                            ? "No assigned voyage reports matched your filters.<br />Try another Flight No, date, or board point."
                            : "No voyage reports matched your filters.<br />Try another Flight No, date, or board point."
                    );
                    return;
                }

                showState("summary");
                renderSummary();
            }

            if (el.searchForm) {
                el.searchForm.addEventListener("submit", function (event) {
                    event.preventDefault();
                    state.filterFlightNo = el.flightNo ? el.flightNo.value.trim() : "";
                    state.filterDate = normalizeDateInput(el.flightDate ? el.flightDate.value : "");
                    state.filterBoardPoint = el.boardPoint ? el.boardPoint.value.trim() : "";
                    state.summarySearch = "";
                    state.summaryPage = 1;
                    state.selectedId = "";
                    state.selectedTab = "general";
                    state.searched = true;
                    if (el.summarySearch) el.summarySearch.value = "";
                    renderView();
                });
            }

            if (el.summarySearch) {
                el.summarySearch.addEventListener("input", function () {
                    state.summarySearch = this.value.trim();
                    state.summaryPage = 1;
                    renderView();
                });
            }

            if (el.entriesSelect) {
                el.entriesSelect.addEventListener("change", function () {
                    state.summaryEntries = parseInt(this.value, 10);
                    state.summaryPage = 1;
                    renderSummary();
                });
            }

            if (el.prevBtn) {
                el.prevBtn.addEventListener("click", function () {
                    if (state.summaryPage <= 1) return;
                    state.summaryPage -= 1;
                    renderSummary();
                });
            }

            if (el.nextBtn) {
                el.nextBtn.addEventListener("click", function () {
                    const total = summaryRows().length;
                    const pages = Math.max(1, Math.ceil(total / state.summaryEntries));
                    if (state.summaryPage >= pages) return;
                    state.summaryPage += 1;
                    renderSummary();
                });
            }

            if (el.backBtn) {
                el.backBtn.addEventListener("click", function () {
                    state.selectedId = "";
                    state.selectedTab = "general";
                    renderView();
                });
            }

            document.querySelectorAll(".vr-sort").forEach((th) => {
                th.addEventListener("click", function () {
                    toggleSort(th.getAttribute("data-sort-key") || "flightDate");
                    state.summaryPage = 1;
                    renderSummary();
                });
            });

            if (el.galleryClose) {
                el.galleryClose.addEventListener("click", function () {
                    setHidden(el.galleryModal, true);
                });
            }

            if (el.galleryModal) {
                el.galleryModal.addEventListener("click", function (event) {
                    if (event.target && event.target.hasAttribute("data-gallery-close")) {
                        setHidden(el.galleryModal, true);
                    }
                });
            }

            renderView();
        });
    </script>
}

