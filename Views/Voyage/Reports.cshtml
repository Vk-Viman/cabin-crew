                        total: 141
                    },
                    crewInformation: [
                        { cat: "PUR", empNo: "CCM-901", name: "Alice Brown", promotionDate: "2022-09-10", gender: "Female", nationality: "LK", onboard: "Yes", position: "L1", safetySign: "Yes", sign: "Yes" },
                        { cat: "FA", empNo: "CCM-902", name: "Robert Smith", promotionDate: "2024-01-10", gender: "Male", nationality: "LK", onboard: "Yes", position: "R3", safetySign: "Yes", sign: "Yes" }
                    ],
                    regulatory: [
                        { label: "Transit Baggage Check Carried Out", value: "Yes" },
                        { label: "Aerosol Sprayed", value: "Yes" },
                        { label: "General Declaration Completed", value: "Yes" },
                        { label: "First Aid Kits Sealed", value: "Yes" },
                        { label: "Relevant Announcements for the sector/s", value: "Standard safety and arrival announcements completed" }
                    ],
                    safetyConfirmation: [
                        { cat: "PUR", name: "Alice Brown", staffId: "CCM-901", sign: "Yes" },
                        { cat: "FA", name: "Robert Smith", staffId: "CCM-902", sign: "Yes" }
                    ],
                    incidents: [],
                    delayReport: "No operational delay recorded.",
                    generalComments: "Normal service flow with no irregularities.",
                    snyCrew: [
                        { cat: "CS", pos: "R4", name: "Kevin Fernando", staffId: "CCM-905", sign: "Yes" }
                    ],
                    passengers: [
                        { passengerName: "Hannah Smith", seatNumber: "14B", ticketNumber: "XYZ555", pnrNumber: "PNR-2001" }
                    ],
                    flySmiles: [
                        { cabin: "EY", flySmilesNo: "FS-77901", memberName: "Nadeesha Silva", tier: "Silver", seatNo: "15A" }
                    ],
                    specialNeeds: [],
                    neighborFreeSeat: [],
                    water: "22 liters remaining on arrival",
                    meals: [
                        { mealType: "EY", measurementUnit: "Trays", bcCateredMeals: 16, bcRemainingMeals: 1, eyCateredMeals: 124, eyRemainingMeals: 8 }
                    ]
                }
            ];

            const state = {
                searched: false,
                selectedId: "",
                selectedTab: "general",
                filterFlightNo: "",
                filterDate: "",
                filterBoardPoint: "",
                summarySearch: "",
                summaryEntries: 10,
                summaryPage: 1,
                sort: { key: "flightDate", dir: "desc" }
            };

            const rawRole = localStorage.getItem("cc_user_role") || "Ground User";
            const currentRole = (rawRole === "Admin" || rawRole === "Ground User") ? rawRole : "Ground User";
            const isGroundUser = currentRole === "Ground User";

            function getAssignedFlightSet() {
                if (!isGroundUser) return null;

                try {
                    const raw = localStorage.getItem("cc_assigned_flights") || "[]";
                    const parsed = JSON.parse(raw);
                    const list = Array.isArray(parsed) ? parsed : [];
                    const normalized = list
                        .map((flightNo) => String(flightNo || "").trim().toUpperCase())
                        .filter(Boolean);
                    return new Set(normalized);
                } catch (_error) {
                    return new Set();
                }
            }

            const assignedFlightSet = getAssignedFlightSet();

            const el = {
                searchCard: document.getElementById("voyageSearchCard"),
                searchForm: document.getElementById("voyageReportsForm"),
                flightNo: document.getElementById("flightNo"),
                flightDate: document.getElementById("flightDate"),
                boardPoint: document.getElementById("boardPoint"),
                emptyState: document.getElementById("voyageEmptyState"),
                summaryState: document.getElementById("voyageSummaryState"),
                summaryBody: document.getElementById("voyageSummaryBody"),
                recordBadge: document.getElementById("voyageRecordBadge"),
                summarySearch: document.getElementById("voyageSummarySearch"),
                entriesSelect: document.getElementById("voyageEntriesSelect"),
                pagingInfo: document.getElementById("voyagePagingInfo"),
                prevBtn: document.getElementById("voyagePrevBtn"),
                pageBtn: document.getElementById("voyagePageBtn"),
                nextBtn: document.getElementById("voyageNextBtn"),
                detailState: document.getElementById("voyageDetailState"),
                backBtn: document.getElementById("voyageBackBtn"),
                bannerFlight: document.getElementById("voyageBannerFlight"),
                bannerRoute: document.getElementById("voyageBannerRoute"),
                bannerDate: document.getElementById("voyageBannerDate"),
                bannerPax: document.getElementById("voyageBannerPax"),
                bannerCrew: document.getElementById("voyageBannerCrew"),
                bannerIncidents: document.getElementById("voyageBannerIncidents"),
                tabStrip: document.getElementById("voyageTabStrip"),
                detailSections: document.getElementById("voyageDetailSections"),
                galleryModal: document.getElementById("voyageGalleryModal"),
                galleryClose: document.getElementById("voyageGalleryCloseBtn"),
                galleryBody: document.getElementById("voyageGalleryBody"),
                galleryTitle: document.getElementById("voyageGalleryTitle")
            };

            function setHidden(node, hidden) {
                if (!node) return;
                node.classList.toggle("d-none", hidden);
            }

            function setEmptyStateText(titleText, bodyHtml) {
                if (!el.emptyState) return;
                const title = el.emptyState.querySelector(".vr-empty-title");
                const text = el.emptyState.querySelector(".vr-empty-text");
                if (title) title.textContent = titleText;
                if (text) text.innerHTML = bodyHtml;
            }

            function scopedReports() {
                if (!isGroundUser) return [...voyageReports];
                if (!assignedFlightSet || !assignedFlightSet.size) return [];
                return voyageReports.filter((report) => assignedFlightSet.has(String(report.flightNo || "").toUpperCase()));
            }

            function dateLabel(value) {
                if (!value) return "";
                const parts = value.split("-");
                if (parts.length !== 3) return value;
                return `${parts[2]} / ${parts[1]} / ${parts[0]}`;
            }

            function normalizeDateInput(value) {
                const raw = (value || "").trim();
                if (!raw) return "";
                if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
                const match = raw.match(/^(\d{1,2})\s*\/\s*(\d{1,2})\s*\/\s*(\d{2}|\d{4})$/);
                if (!match) return "";
                const day = String(match[1]).padStart(2, "0");
                const month = String(match[2]).padStart(2, "0");
                const year = match[3].length === 2 ? `20${match[3]}` : match[3];
                return `${year}-${month}-${day}`;
            }

            function sortRows(rows, sort) {
                return [...rows].sort((a, b) => {
                    const av = String(a[sort.key] ?? "").toLowerCase();
                    const bv = String(b[sort.key] ?? "").toLowerCase();
                    if (sort.key === "flightDate") {
                        return sort.dir === "asc"
                            ? new Date(a.flightDate) - new Date(b.flightDate)
                            : new Date(b.flightDate) - new Date(a.flightDate);
                    }
                    if (av < bv) return sort.dir === "asc" ? -1 : 1;
                    if (av > bv) return sort.dir === "asc" ? 1 : -1;
                    return 0;
                });
            }

            function toggleSort(key) {
                if (state.sort.key === key) {
                    state.sort.dir = state.sort.dir === "asc" ? "desc" : "asc";
                    return;
                }
                state.sort.key = key;
                state.sort.dir = "asc";
            }

            function summaryRows() {
                let rows = scopedReports();
                const flightNo = state.filterFlightNo.toLowerCase();
                const boardPoint = state.filterBoardPoint.toLowerCase();
                const date = state.filterDate;
                const summarySearch = state.summarySearch.toLowerCase();

                if (flightNo) rows = rows.filter((row) => row.flightNo.toLowerCase().includes(flightNo));
                if (boardPoint) rows = rows.filter((row) => row.boardPoint.toLowerCase().includes(boardPoint));
                if (date) rows = rows.filter((row) => row.flightDate === date);
                if (summarySearch) {
                    rows = rows.filter((row) =>
                        [row.flightDate, row.flightNo, row.boardPoint, row.offPoint].some((value) => String(value).toLowerCase().includes(summarySearch))
                    );
                }

                return sortRows(rows, state.sort);
            }

            function getSelectedReport() {
                return scopedReports().find((report) => `${report.flightNo}::${report.flightDate}` === state.selectedId) || null;
            }

            function yesNoBadge(value) {
                const text = String(value || "");
                const lower = text.toLowerCase();
                const klass = lower === "yes" ? "yes" : lower === "no" ? "no" : "text";
                return `<span class="vr-pill ${klass}">${text}</span>`;
            }

            function yesNoIcon(value) {
                const text = String(value || "").toLowerCase();
                const yes = text === "yes";
                const icon = yes
                    ? `<svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="10" cy="10" r="9" fill="#16A34A" /><path d="M6 10.3l2.3 2.3L14.2 6.8" stroke="#fff" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>`
                    : `<svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="10" cy="10" r="9" fill="#9CA3AF" /><path d="M6.4 6.4l7.2 7.2M13.6 6.4l-7.2 7.2" stroke="#fff" stroke-width="1.8" stroke-linecap="round" /></svg>`;
                return `<span class="vr-yn-icon ${yes ? "yes" : "no"}">${icon}</span>`;
            }

            function catBadge(value) {
                return `<span class="vr-cat-badge">${value}</span>`;
            }

            function signBadge(value) {
                const text = String(value || "");
                return `<span class="vr-sign ${text.toLowerCase() === "yes" ? "yes" : "no"}">${text}</span>`;
            }

            function safetySignPill(value) {
                const text = String(value || "").toUpperCase();
                const yes = text === "YES";
                return `<span class="vr-safety-sign ${yes ? "yes" : "no"}">${text}</span>`;
            }

            function sectionHeaderIcon(type) {
                if (type === "warning") {
                    return `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 3.8 21.1 19a1.1 1.1 0 0 1-.95 1.6H3.85A1.1 1.1 0 0 1 2.9 19L12 3.8Z" fill="currentColor" opacity="0.2"/><path d="M12 7v7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="17.2" r="1.1" fill="currentColor"/></svg>`;
                }

                if (type === "water") {
                    return `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 3.8c2.7 3 5.2 6.4 5.2 9.2a5.2 5.2 0 1 1-10.4 0c0-2.8 2.5-6.2 5.2-9.2Z" stroke="currentColor" stroke-width="1.8"/><path d="M9.2 13.6c0 1.5 1 2.7 2.8 2.9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/></svg>`;
                }

                if (type === "meal") {
                    return `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="9" cy="19" r="1.6" stroke="currentColor" stroke-width="1.6"/><circle cx="17" cy="19" r="1.6" stroke="currentColor" stroke-width="1.6"/><path d="M4 5h2l1.7 8.2a1 1 0 0 0 1 .8h8.8a1 1 0 0 0 1-.8L20 8H7.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
                }

                return `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.8"/><path d="M5.8 19c.7-3.3 3.3-5.2 6.2-5.2 2.9 0 5.5 1.9 6.2 5.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`;
            }

            function regulatoryStatus(item) {
                const label = String(item?.label || "").toLowerCase();
                const value = String(item?.value || "").toLowerCase();
                if (label.includes("meal services produce")) return "pending";
                if (value === "yes") return "yes";
                if (value === "no") return "no";
                return "pending";
            }

            function regulatoryStatusIcon(status) {
                if (status === "yes") {
                    return `<span class="vr-reg-status yes" aria-hidden="true"><svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" fill="none"><circle cx="10" cy="10" r="8" stroke="#00A63E" stroke-width="2"/><path d="M6.4 10.2l2.1 2.2 5-5" stroke="#00A63E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>`;
                }
                if (status === "no") {
                    return `<span class="vr-reg-status no" aria-hidden="true"><svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" fill="none"><circle cx="10" cy="10" r="8" stroke="#9CA3AF" stroke-width="2"/><path d="M7 7l6 6M13 7l-6 6" stroke="#9CA3AF" stroke-width="1.8" stroke-linecap="round"/></svg></span>`;
                }
                return `<span class="vr-reg-status pending" aria-hidden="true"><svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" fill="none"><circle cx="10" cy="10" r="8" fill="#D1D5DB" stroke="#A1A1AA" stroke-width="1.5"/></svg></span>`;
            }

            function dataTableCard(title, iconUrl, headers, rows, emptyMessage, options) {
                const opts = options || {};
                const count = Number(opts.count) || 0;
                const titleSuffix = opts.titleSuffix === undefined ? "members" : String(opts.titleSuffix);
                const cardClass = opts.cardClass || "";
                const headerClass = opts.headerClass || "";
                const bodyClass = opts.bodyClass || "";
                const tableClass = opts.tableClass || "vr-crew-table";
                const tableKey = opts.tableKey || title.toLowerCase().replace(/\s+/g, "-");
                const defaultEntries = Number(opts.defaultEntries) || 10;
                const iconHtml = opts.iconMarkup || `<img src="${iconUrl}" alt="" />`;
                const body = rows.length
                    ? rows.join("")
                    : `<tr><td colspan="${headers.length}" class="vr-empty-row">${emptyMessage}</td></tr>`;
                const titleText = titleSuffix ? `${title} (${count} ${titleSuffix})` : title;
                const footer = opts.showFooter !== false
                    ? `<div class="vr-table-footer vr-passenger-footer">
                            <span class="vr-js-info">${opts.footerLabel || `Showing 1 to ${count} of ${count} entries`}</span>
                            <div class="vr-pager-btns">
                                <button type="button" class="vr-js-prev" disabled>Previous</button>
                                <button type="button" class="active vr-js-page">1</button>
                                <button type="button" class="vr-js-next" disabled>Next</button>
                            </div>
                        </div>`
                    : "";

                return `
                    <section class="vr-section-card vr-data-card ${cardClass}" data-table-key="${tableKey}">
                        <header class="vr-section-header vr-data-card-header ${headerClass}">
                            <span class="vr-data-header-icon" aria-hidden="true">${iconHtml}</span>
                            <span>${titleText}</span>
                        </header>
                        <div class="vr-section-body vr-data-card-body ${bodyClass}">
                            <div class="vr-toolbar vr-inline-toolbar">
                                <div class="vr-toolbar-left">
                                    <span>Show</span>
                                    <select class="vr-toolbar-select vr-js-entries" aria-label="Entries per page">
                                        <option value="10" ${defaultEntries === 10 ? "selected" : ""}>10</option>
                                        <option value="25" ${defaultEntries === 25 ? "selected" : ""}>25</option>
                                        <option value="50" ${defaultEntries === 50 ? "selected" : ""}>50</option>
                                    </select>
                                    <span>entries</span>
                                    <span class="vr-badge">${count} records</span>
                                </div>
                                <div class="vr-toolbar-search">
                                    <span class="vr-toolbar-search-icon" aria-hidden="true">
                                        <img src="/images/icons/search-white.svg" alt="" />
                                    </span>
                                    <input class="vr-js-search" type="text" placeholder="${opts.searchPlaceholder || "Search..."}" />
                                </div>
                            </div>
                            <div class="vr-table-wrap">
                                <table class="vr-table vr-detail-table ${tableClass}">
                                    <thead>
                                        <tr>${headers.map((header) => `<th>${header}</th>`).join("")}</tr>
                                    </thead>
                                    <tbody class="vr-js-tbody" data-colspan="${headers.length}" data-empty-message="${emptyMessage}">${body}</tbody>
                                </table>
                            </div>
                            ${footer}
                        </div>
                    </section>`;
            }

            function sectionCard(title, body, className, attributes) {
                const extraAttrs = attributes ? ` ${attributes}` : "";
                return `<section class="vr-section-card ${className || ""}"${extraAttrs}><header class="vr-section-header">${title}</header><div class="vr-section-body">${body}</div></section>`;
            }

            function emptyIncidentCard() {
                return `
                    <section class="vr-section-card vr-incident-empty-card">
                        <header class="vr-section-header vr-incident-empty-header">
                            <span class="vr-incident-header-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 3.8 21.1 19a1.1 1.1 0 0 1-.95 1.6H3.85A1.1 1.1 0 0 1 2.9 19L12 3.8Z" fill="currentColor" opacity="0.18" />
                                    <path d="M12 7v7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                                    <circle cx="12" cy="17.2" r="1.1" fill="currentColor" />
                                </svg>
                            </span>
                            <span>No Incidents Reported</span>
                        </header>
                        <div class="vr-section-body">
                            <div class="vr-incident-empty-panel">
                                <div class="vr-incident-empty-mark">✓</div>
                                <div class="vr-incident-empty-title">Flight Completed Successfully</div>
                                <div class="vr-incident-empty-text">No incidents reported during this voyage</div>
                            </div>
                        </div>
                    </section>`;
