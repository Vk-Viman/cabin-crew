@{
    ViewData["Title"] = "Voyage Reports";
}

<div class="vr-page">
    <section id="voyageSearchCard" class="vr-card vr-search-card">
        <form id="voyageReportsForm" class="vr-search-form">
            <div class="vr-form-row-inline">
                <div class="vr-form-field">
                    <label for="flightNo">Flight No</label>
                    <input type="text" id="flightNo" name="flightNo" placeholder="ul" />
                </div>

                <div class="vr-form-field">
                    <label for="flightDate">Flight Date (Local)</label>
                    <div class="vr-date-input-wrapper">
                        <input type="text" id="flightDate" name="flightDate" placeholder="DD/MM/YY" />
                    </div>
                </div>

                <div class="vr-form-field">
                    <label for="boardPoint">Board Point</label>
                    <input type="text" id="boardPoint" name="boardPoint" placeholder="cmb" />
                </div>

                <button type="submit" class="vr-btn-search-inline">
                    <img class="vr-search-icon" src="/images/icons/search-white.svg" alt="" aria-hidden="true" />
                    Search
                </button>
            </div>
        </form>
    </section>

    <section id="voyageEmptyState" class="vr-card vr-empty-card">
        <div class="vr-empty-state">
            <div class="vr-empty-icon">
                <img src="/images/icons/empty-state.svg" alt="" aria-hidden="true" />
            </div>
            <h3 class="vr-empty-title">Ready to Search</h3>
            <p class="vr-empty-text">Use the filters above to search for voyage reports by flight.<br />Enter flight details to get started.</p>
        </div>
    </section>

    <section id="voyageSummaryState" class="vr-card vr-summary-card d-none">
        <div class="vr-toolbar">
            <div class="vr-toolbar-left">
                <span>Show</span>
                <select id="voyageEntriesSelect">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
                <span>entries</span>
                <span id="voyageRecordBadge" class="vr-badge">0 records</span>
            </div>

            <div class="vr-toolbar-search">
                <span class="vr-toolbar-search-icon" aria-hidden="true">
                    <img src="/images/icons/search-white.svg" alt="" />
                </span>
                <input id="voyageSummarySearch" type="text" placeholder="Search voyage reports..." />
            </div>
        </div>

        <div class="vr-table-wrap">
            <table class="vr-table">
                <thead>
                    <tr>
                        <th class="vr-sort" data-sort-key="flightDate">Flight Date</th>
                        <th class="vr-sort" data-sort-key="flightNo">Flight No</th>
                        <th class="vr-sort" data-sort-key="boardPoint">Board Point</th>
                        <th class="vr-sort" data-sort-key="offPoint">Off Point</th>
                    </tr>
                </thead>
                <tbody id="voyageSummaryBody"></tbody>
            </table>
        </div>

        <div class="vr-table-footer">
            <span id="voyagePagingInfo">Showing 0 to 0 of 0 entries</span>
            <div class="vr-pager-btns">
                <button id="voyagePrevBtn" type="button">Previous</button>
                <button id="voyagePageBtn" type="button" class="active">1</button>
                <button id="voyageNextBtn" type="button">Next</button>
            </div>
        </div>
    </section>

    <section id="voyageDetailState" class="d-none">
        <button id="voyageBackBtn" type="button" class="vr-back-btn">Back to Voyage Reports</button>

        <section class="vr-banner">
            <div class="vr-banner-left">
                <div class="vr-banner-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 12.2l15.2-6.4c.7-.3 1.4.4 1.1 1.1l-6.4 15.2c-.3.7-1.3.6-1.5-.1l-1.6-5.2-5.2-1.6c-.7-.2-.8-1.2-.1-1.5Z" fill="currentColor" />
                        <path d="M11 13l5-5" stroke="#fff" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </div>
                <div>
                    <div id="voyageBannerFlight" class="vr-banner-main">Flight UL504</div>
                    <div class="vr-banner-meta-row">
                        <div class="vr-banner-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M12 21s6-5.1 6-10.3A6 6 0 1 0 6 10.7C6 15.9 12 21 12 21Z" stroke="currentColor" stroke-width="1.6" />
                                <circle cx="12" cy="10.6" r="2" fill="currentColor" />
                            </svg>
                            <span id="voyageBannerRoute" class="vr-banner-sub">CMB → KUL</span>
                        </div>
                        <div class="vr-banner-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <rect x="4" y="5" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.6" />
                                <path d="M4 9h16" stroke="currentColor" stroke-width="1.6" />
                                <path d="M8 3.5v3M16 3.5v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                            </svg>
                            <span id="voyageBannerDate" class="vr-banner-sub">20 / 11 / 2025</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="vr-banner-right">
                <div class="vr-banner-chip"><span>Total PAX</span><strong id="voyageBannerPax">248</strong></div>
                <div class="vr-banner-chip"><span>Crew</span><strong id="voyageBannerCrew">4</strong></div>
                <div class="vr-banner-chip"><span>Incidents</span><strong id="voyageBannerIncidents">0</strong></div>
            </div>
        </section>

        <div class="vr-tab-shell">
            <div id="voyageTabStrip" class="vr-tab-strip" role="tablist" aria-label="Voyage report sections"></div>
            <div id="voyageDetailSections" class="vr-detail-sections"></div>
        </div>
    </section>

    <div id="voyageGalleryModal" class="vr-gallery-modal d-none" role="dialog" aria-modal="true" aria-labelledby="voyageGalleryTitle">
        <div class="vr-gallery-backdrop" data-gallery-close></div>
        <div class="vr-gallery-panel">
            <div class="vr-gallery-header">
                <h4 id="voyageGalleryTitle">Incident Images</h4>
                <button type="button" id="voyageGalleryCloseBtn" class="vr-gallery-close" aria-label="Close gallery">×</button>
            </div>
            <div id="voyageGalleryBody" class="vr-gallery-body"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
