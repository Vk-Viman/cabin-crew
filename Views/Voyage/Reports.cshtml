                const regulatoryPrimary = regulatoryCards.slice(0, 4).join("");
                const regulatoryBriefing = regulatoryCards.slice(4).join("");
                const regulatory = sectionCard(
                    `<span class="vr-reg-header-title"><span class="vr-reg-header-icon">✓</span>Regulatory Compliance</span>`,
                    report.regulatory.length
                        ? `<div class="vr-regulatory-wrap">
                            <div class="vr-reg-grid">${regulatoryPrimary}</div>
                            <div class="vr-reg-divider"></div>
                            <div class="vr-reg-subtitle"><span class="vr-reg-subtitle-mark"></span>Mandatory Topics Discussed at SEP Briefing</div>
                            <div class="vr-reg-grid">${regulatoryBriefing}</div>
                        </div>`
                        : `<div class="vr-empty-row">No regulatory records available.</div>`,
                    "vr-regulatory-card"
                );

                const safetyRows = report.safetyConfirmation.map((item) => `
                    <tr>
                        <td>${catBadge(item.cat)}</td>
                        <td>${item.name}</td>
                        <td>${item.staffId}</td>
                        <td>${safetySignPill(item.sign)}</td>
                    </tr>
                `);
                const safety = sectionCard(
                    `<span class="vr-reg-header-title"><span class="vr-reg-header-icon">✓</span>Confirmation of Safety (${report.safetyConfirmation.length} confirmations)</span>`,
                    `<div class="vr-safety-wrap">
                        <div class="vr-safety-toolbar">
                            <div class="vr-safety-toolbar-left">
                                <span>Show</span>
                                <select class="vr-toolbar-select vr-js-entries" aria-label="Entries per page">
                                    <option value="10" selected>10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                </select>
                                <span>entries</span>
                                <span class="vr-badge">${report.safetyConfirmation.length} records</span>
                            </div>
                            <div class="vr-safety-toolbar-search">
                                <span class="vr-toolbar-search-icon" aria-hidden="true">
                                    <img src="/images/icons/search-muted.svg" alt="" />
                                </span>
                                <input class="vr-js-search" type="text" placeholder="Search safety confirmations..." />
                            </div>
                        </div>
                        <div class="vr-table-wrap">
                            <table class="vr-table vr-detail-table vr-safety-table">
                                <thead>
                                    <tr>
                                        <th>CAT</th>
                                        <th>Name</th>
                                        <th>Staff ID</th>
